---
import Layout from '../layouts/Layout.astro';
import { PB_URL } from '../utils/config.js';
import { getNewsDetailUrl, getNewsUrl, getProfilUrl, getAplikasiUrl, getAcademyUrl, getAutomasiUrl } from '../utils/routes.js';

const profileRes = await fetch(`${PB_URL}/api/collections/profiles/records?limit=1`);
const profileData = await profileRes.json();
const profile = profileData.items[0] || { visi: '', misi: [], tim: [] };

const newsRes = await fetch(`${PB_URL}/api/collections/news/records?sort=-date&perPage=3`);
const newsData = await newsRes.json();
const latestNews = newsData.items || [];

function formatDate(dateStr) {
    var d = new Date(dateStr);
    var months = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
    return d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
}
---

<Layout title="CV. Sarjana Komputer Indonesia — Solusi IT & Pengembangan SDM Digital">
  <!-- ===== HERO ===== -->
  <section class="company-hero">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-8">
          <div class="hero-badge"><i class="bi bi-building"></i> CV. Sarjana Komputer Indonesia</div>
          <h1>Mitra <span>Transformasi Digital</span> & Jembatan Karier Menuju Industri Global</h1>
          <p class="hero-sub">Kami menyediakan solusi IT profesional — dari pengembangan aplikasi, automasi bisnis berbasis AI, hingga academy IT — untuk pemerintah, korporasi, UMKM, dan masyarakat Indonesia.</p>
          <div class="d-flex flex-wrap gap-2">
            <a href="#layanan" class="btn-primary-custom"><i class="bi bi-grid"></i> Lihat Layanan</a>
            <a href={getProfilUrl()} class="btn-outline-custom" style="border-color:rgba(255,255,255,0.2);color:rgba(255,255,255,0.7);">Tentang Kami <i class="bi bi-arrow-right"></i></a>
          </div>
          <div class="hero-meta">
            <span class="hero-meta-item"><i class="bi bi-geo-alt-fill"></i> Baubau, Sulawesi Tenggara</span>
            <span class="hero-meta-item"><i class="bi bi-calendar-check"></i> Berdiri Sejak 2021</span>
            <span class="hero-meta-item"><i class="bi bi-people-fill"></i> 6 Tenaga Ahli</span>
            <span class="hero-meta-item"><i class="bi bi-building-check"></i> Melayani Pemerintah & Swasta</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <section class="stats-section">
    <div class="container">
      <div class="row g-2">
        <div class="col-6 col-md-3"><div class="stat-card"><div class="num">10+</div><div class="label">Proyek Terselesaikan</div></div></div>
        <div class="col-6 col-md-3"><div class="stat-card"><div class="num">6</div><div class="label">Tenaga Ahli</div></div></div>
        <div class="col-6 col-md-3"><div class="stat-card"><div class="num">3</div><div class="label">Segmen Layanan</div></div></div>
        <div class="col-6 col-md-3"><div class="stat-card"><div class="num">120+</div><div class="label">Alumni Academy</div></div></div>
      </div>
    </div>
  </section>

  <!-- ===== TENTANG + VISI MISI ===== -->
  <section class="section about-home" id="tentang">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem">
          <i class="bi bi-info-circle"></i> Tentang Kami
        </div>
        <h2 class="section-title">CV. Sarjana Komputer Indonesia</h2>
        <p class="section-subtitle">Perusahaan pengembangan IT dan solusi digital yang berbasis di Baubau, Sulawesi Tenggara — berkomitmen mendorong transformasi digital dan pengembangan talenta IT di Indonesia.</p>
      </div>
      <div class="row g-3">
        <div class="col-lg-4">
          <div class="visi-card">
            <span class="icon">🎯</span>
            <h5>Visi</h5>
            <p>{profile.visi || 'Mitra terdepan transformasi digital dan jembatan karier menuju industri global.'}</p>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="row g-2">
            {profile.misi && profile.misi.length > 0 ? (
              profile.misi.map((m: string, idx: number) => (
                <div class="col-12">
                  <div class="misi-card">
                    <div class="num">{idx + 1}</div>
                    <div>
                      <p style="margin:0; font-size:0.95rem; font-weight: 500; color: var(--gray-600);">{m}</p>
                    </div>
                  </div>
                </div>
              ))
            ) : (
              <>
                <div class="col-12"><div class="misi-card"><div class="num">1</div><div><h6>Menyediakan Solusi IT & Digitalisasi</h6><p>Untuk pemerintah, swasta, dan masyarakat melalui pengembangan aplikasi, sistem informasi, dan infrastruktur digital.</p></div></div></div>
                <div class="col-12"><div class="misi-card"><div class="num">2</div><div><h6>Menjembatani Pendidikan & Industri</h6><p>Menghubungkan pendidikan, pengembangan talenta, dan riset dengan kebutuhan industri teknologi melalui academy dan program magang.</p></div></div></div>
                <div class="col-12"><div class="misi-card"><div class="num">3</div><div><h6>Mendorong Digitalisasi Daerah</h6><p>Mempercepat adopsi teknologi digital di berbagai daerah untuk mendorong kemajuan ekonomi dan pelayanan publik yang lebih baik.</p></div></div></div>
              </>
            )}
          </div>
        </div>
      </div>
      <div class="text-center mt-3">
        <a href={getProfilUrl()} class="btn-outline-custom">Profil Lengkap <i class="bi bi-arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ===== LAYANAN ===== -->
  <section class="section section-alt" id="layanan">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem">
          <i class="bi bi-grid"></i> Layanan Kami
        </div>
        <h2 class="section-title">Solusi IT untuk Setiap Kebutuhan</h2>
        <p class="section-subtitle">Dari pemerintah hingga individu — kami siap membantu transformasi digital Anda.</p>
      </div>
      <div class="row g-3">
        <div class="col-md-6 col-lg-3">
          <a href={getAplikasiUrl()} style="text-decoration:none;color:inherit">
            <div class="service-card-home">
              <div class="serv-icon" style="background:var(--gradient)"><i class="bi bi-window-stack"></i></div>
              <h5>Jasa Aplikasi</h5>
              <p>Pembuatan aplikasi web, Android, dan desktop custom — termasuk sistem informasi, e-government, dan platform bisnis.</p>
              <div class="tags"><span>Web</span><span>Android</span><span>Desktop</span><span>E-Government</span></div>
              <span class="serv-link">Selengkapnya <i class="bi bi-arrow-right"></i></span>
            </div>
          </a>
        </div>
        <div class="col-md-6 col-lg-3">
          <a href={getAutomasiUrl()} style="text-decoration:none;color:inherit">
            <div class="service-card-home">
              <div class="serv-icon" style="background:linear-gradient(135deg,#f59e0b,#f97316)"><i class="bi bi-robot"></i></div>
              <h5>Automasi & AI</h5>
              <p>Otomatisasi proses bisnis, chatbot AI, document processing, dan workflow automation untuk efisiensi operasional maksimal.</p>
              <div class="tags"><span>Chatbot</span><span>Workflow</span><span>AI</span><span>Otomatisasi</span></div>
              <span class="serv-link">Selengkapnya <i class="bi bi-arrow-right"></i></span>
            </div>
          </a>
        </div>
        <div class="col-md-6 col-lg-3">
          <a href={getAcademyUrl()} style="text-decoration:none;color:inherit">
            <div class="service-card-home">
              <div class="serv-icon" style="background:linear-gradient(135deg,#10b981,#059669)"><i class="bi bi-mortarboard-fill"></i></div>
              <h5>Academy IT</h5>
              <p>Bootcamp Full-stack, bimbingan skripsi/TA, program magang, dan workshop IT untuk mencetak talenta digital profesional.</p>
              <div class="tags"><span>Bootcamp</span><span>Bimbingan Skripsi</span><span>Magang</span><span>Workshop</span></div>
              <span class="serv-link">Selengkapnya <i class="bi bi-arrow-right"></i></span>
            </div>
          </a>
        </div>
        <div class="col-md-6 col-lg-3">
          <a href={getProfilUrl()} style="text-decoration:none;color:inherit">
            <div class="service-card-home">
              <div class="serv-icon" style="background:linear-gradient(135deg,#8b5cf6,#6366f1)"><i class="bi bi-building"></i></div>
              <h5>Profil Perusahaan</h5>
              <p>Informasi lengkap tentang CV. Sarjana Komputer Indonesia — tim, proyek, legalitas, dan klien yang telah mempercayai kami.</p>
              <div class="tags"><span>Tim</span><span>Proyek</span><span>Legalitas</span><span>Klien</span></div>
              <span class="serv-link">Selengkapnya <i class="bi bi-arrow-right"></i></span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROYEK UNGGULAN ===== -->
  <section class="section" id="proyek">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(16,185,129,0.1);color:#059669;border-color:rgba(16,185,129,0.15);display:inline-flex;margin-bottom:1rem">
          <i class="bi bi-trophy"></i> Proyek Unggulan
        </div>
        <h2 class="section-title">Yang Telah Kami Kerjakan</h2>
        <p class="section-subtitle">Proyek-proyek nyata yang telah membantu transformasi digital berbagai institusi.</p>
      </div>
      <div class="row g-3">
        <div class="col-md-4">
          <div class="project-card">
            <div class="proj-badge"><i class="bi bi-building"></i> Pemerintahan</div>
            <h5>Sipanda v2.0</h5>
            <p><strong>Sistem Informasi Pendapatan Daerah</strong> — Platform manajemen pendapatan daerah untuk meningkatkan transparansi dan efisiensi pengelolaan PAD.</p>
            <span style="font-size:.78rem;color:var(--gray-400)"><i class="bi bi-geo-alt"></i> Pemerintah Daerah</span>
          </div>
        </div>
        <div class="col-md-4">
          <div class="project-card">
            <div class="proj-badge"><i class="bi bi-heart-pulse"></i> Kesehatan</div>
            <h5>SIMKES</h5>
            <p><strong>Sistem Informasi Manajemen Kesehatan</strong> — Solusi digital untuk manajemen data pasien, pendaftaran, rekam medis, dan pelaporan kesehatan.</p>
            <span style="font-size:.78rem;color:var(--gray-400)"><i class="bi bi-geo-alt"></i> Institusi Kesehatan</span>
          </div>
        </div>
        <div class="col-md-4">
          <div class="project-card">
            <div class="proj-badge"><i class="bi bi-cash-coin"></i> Keuangan</div>
            <h5>E-Retribusi</h5>
            <p><strong>Platform Pembayaran Retribusi Online</strong> — Sistem pembayaran retribusi daerah secara digital untuk kemudahan transaksi dan akuntabilitas.</p>
            <span style="font-size:.78rem;color:var(--gray-400)"><i class="bi bi-geo-alt"></i> Pemerintah Daerah</span>
          </div>
        </div>
      </div>
      <div class="text-center mt-3">
        <a href={getAplikasiUrl()} class="btn-outline-custom">Lihat Portofolio Lengkap <i class="bi bi-arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ===== TIM ===== -->
  <section class="section section-alt" id="tim">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem">
          <i class="bi bi-people"></i> Tim Kami
        </div>
        <h2 class="section-title">Tenaga Ahli Profesional</h2>
        <p class="section-subtitle">Tim muda, kreatif, dan kompeten yang siap mewujudkan solusi digital Anda.</p>
      </div>
      <div class="team-grid-home">
        {profile.tim && profile.tim.length > 0 ? (
          profile.tim.map((t: any) => (
            <div class="team-card-home">
              <img loading="lazy" src={t.image} alt={`${t.name} - ${t.role}`} class="tch-img">
              <div class="tch-body">
                <h5>{t.name}</h5>
                <div class="role-badge">{t.role}</div>
              </div>
            </div>
          ))
        ) : (
          <>
            <div class="team-card-home">
              <img loading="lazy" src="/images/team/direktur.webp" alt="Muhdan Fyan Syah Sofian - Direktur" class="tch-img">
              <div class="tch-body">
                <h5>Muhdan Fyan Syah Sofian, S.Kom</h5>
                <div class="role-badge">Direktur</div>
              </div>
            </div>
            <div class="team-card-home">
              <img loading="lazy" src="/images/team/irvan.webp" alt="Irvan - Komisaris" class="tch-img">
              <div class="tch-body">
                <h5>Irvan, S.Kom</h5>
                <div class="role-badge">Komisaris</div>
              </div>
            </div>
            <div class="team-card-home">
              <img loading="lazy" src="/images/team/hayat.webp" alt="Hayatul Habirun - IT Infrastructure Lead" class="tch-img">
              <div class="tch-body">
                <h5>Hayatul Habirun, S.Kom</h5>
                <div class="role-badge">IT Infrastructure Lead</div>
              </div>
            </div>
            <div class="team-card-home">
              <img loading="lazy" src="/images/team/arif-rizal.webp" alt="Arif Rizal - Backend & QA Engineer" class="tch-img">
              <div class="tch-body">
                <h5>Arif Rizal</h5>
                <div class="role-badge">Backend &amp; QA Engineer</div>
              </div>
            </div>
            <div class="team-card-home">
              <img loading="lazy" src="/images/team/ahmad-dahsan.webp" alt="Ahmad Dahsan - DevOps & Software Engineer" class="tch-img">
              <div class="tch-body">
                <h5>Ahmad Dahsan</h5>
                <div class="role-badge">DevOps &amp; Software Engineer</div>
              </div>
            </div>
            <div class="team-card-home">
              <img loading="lazy" src="/images/team/andi-rifqial-nur.webp" alt="Andi Rifqial Nur - Software Engineer" class="tch-img">
              <div class="tch-body">
                <h5>Andi Rifqial Nur</h5>
                <div class="role-badge">Software Engineer</div>
              </div>
            </div>
          </>
        )}
      </div>
      <div class="text-center mt-3">
        <a href={`${getProfilUrl()}#struktur`} class="btn-outline-custom">Lihat Struktur Organisasi <i class="bi bi-arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ===== KLIEN & MITRA ===== -->
  <section class="section" id="mitra">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(245,158,11,0.1);color:#d97706;border-color:rgba(245,158,11,0.15);display:inline-flex;margin-bottom:1rem">
          <i class="bi bi-handshake"></i> Klien & Mitra
        </div>
        <h2 class="section-title">Dipercaya oleh</h2>
        <p class="section-subtitle">Mitra strategis yang telah bekerja sama dalam transformasi digital.</p>
      </div>
      <div class="row g-2 justify-content-center">
        <div class="col-6 col-md-3"><div class="client-card-home pmi"><div class="client-icon">🏫</div><h6>Pondok Informatika</h6><p>Pusat inkubasi talenta digital & mitra strategis</p></div></div>
        <div class="col-6 col-md-3"><div class="client-card-home tl"><div class="client-icon">👥</div><h6>Komunitas Programmer Baubau</h6><p>Wadah kolaborasi programmer lokal</p></div></div>
        <div class="col-6 col-md-3"><div class="client-card-home gov"><div class="client-icon">🤝</div><h6>CV Ghonim</h6><p>Mitra strategis implementasi aplikasi</p></div></div>
      </div>
    </div>
  </section>

  <!-- ===== BERITA ===== -->
  <section class="section section-alt" id="berita">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
          <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:.5rem">
            <i class="bi bi-newspaper"></i> Berita Teknologi
          </div>
          <h2 class="section-title" style="margin:0">Update Teknologi Terbaru</h2>
        </div>
        <a href={getNewsUrl()} style="font-size:.85rem;color:var(--primary);font-weight:600;">Kunjungi Portal Berita <i class="bi bi-arrow-right"></i></a>
      </div>
      <div class="row g-3 mt-1">
        {latestNews.length > 0 ? (
          latestNews.map((item: any) => (
            <div class="col-md-4">
              <a href={getNewsDetailUrl(item.slug)} style="text-decoration:none;color:inherit">
                <div class="blog-preview-card">
                  <div class="bp-img" style={`background-image:linear-gradient(rgba(0,0,0,0.1),rgba(0,0,0,0.3)),url('${item.imageUrl || item.image || "https://placehold.co/600x400?text=No+Image"}')`}></div>
                  <div class="bp-body">
                    <div class="bp-cat">{item.category}</div>
                    <h6>{item.title}</h6>
                    <p style="font-size:.75rem;color:var(--gray-400)">{formatDate(item.date)}</p>
                  </div>
                </div>
              </a>
            </div>
          ))
        ) : (
          <div class="col-12 text-center py-4">
            <p style="color:var(--gray-400)">Belum ada berita terbaru.</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <div class="container">
      <h2>Siap Mulai Transformasi Digital?</h2>
      <p>Konsultasi gratis dengan tim kami. Ceritakan kebutuhan Anda, dan kami akan berikan solusi terbaik.</p>
      <div class="d-flex flex-wrap justify-content-center gap-2">
        <a href={profile.whatsapp_link || 'https://wa.me/6283134086899'} class="btn-cta" target="_blank" rel="noopener"><i class="bi bi-whatsapp"></i> Konsultasi Gratis</a>
        <a href={`${getProfilUrl()}#kontak`} class="btn-outline-cta"><i class="bi bi-envelope"></i> Hubungi Kami</a>
      </div>
    </div>
  </section>
</Layout>
