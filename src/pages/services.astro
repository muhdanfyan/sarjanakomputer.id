---
import Layout from "../layouts/Layout.astro";
---

<Layout title="CV. Sarjana Komputer Indonesia — Layanan">
<div class="page-header">
    <div class="container">
        <a href="index.html" style="color:rgba(255,255,255,0.7);text-decoration:none;display:inline-flex;align-items:center;gap:0.4rem;margin-bottom:1rem;font-size:0.9rem"><i class="bi bi-arrow-left"></i> Kembali ke Beranda</a>
        <h1>Layanan Kami</h1>
        <p>Solusi IT lengkap untuk kebutuhan digital Anda</p>
    </div>
</div>

<section style="padding:3rem 0">
    <div class="container">
        <div class="row g-3">
            <div class="col-md-6 col-lg-3">
                <div class="card-custom text-center" style="padding:2rem 1.5rem">
                    <div class="card-icon" style="background:var(--gradient);margin:0 auto 1rem"><i class="bi bi-building"></i></div>
                    <h5 style="font-size:0.95rem">Profil Perusahaan</h5>
                    <p style="font-size:0.82rem;color:var(--gray-500)">Informasi lengkap tentang CV. Sarjana Komputer Indonesia, tim, dan portofolio.</p>
                    <a href="profil/" class="read-more" style="font-size:0.82rem;color:var(--primary);font-weight:600">Selengkapnya <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card-custom text-center" style="padding:2rem 1.5rem">
                    <div class="card-icon" style="background:linear-gradient(135deg,#8b5cf6,#6366f1);margin:0 auto 1rem"><i class="bi bi-window-stack"></i></div>
                    <h5 style="font-size:0.95rem">Jasa Aplikasi</h5>
                    <p style="font-size:0.82rem;color:var(--gray-500)">Pembuatan aplikasi web, mobile Android, dan desktop sesuai kebutuhan bisnis.</p>
                    <a href="aplikasi/" class="read-more" style="font-size:0.82rem;color:var(--primary);font-weight:600">Selengkapnya <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card-custom text-center" style="padding:2rem 1.5rem">
                    <div class="card-icon" style="background:linear-gradient(135deg,#f59e0b,#f97316);margin:0 auto 1rem"><i class="bi bi-robot"></i></div>
                    <h5 style="font-size:0.95rem">Automasi & AI</h5>
                    <p style="font-size:0.82rem;color:var(--gray-500)">Solusi automasi bisnis dan kecerdasan buatan untuk efisiensi operasional.</p>
                    <a href="automasi/" class="read-more" style="font-size:0.82rem;color:var(--primary);font-weight:600">Selengkapnya <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card-custom text-center" style="padding:2rem 1.5rem">
                    <div class="card-icon" style="background:linear-gradient(135deg,#10b981,#059669);margin:0 auto 1rem"><i class="bi bi-mortarboard-fill"></i></div>
                    <h5 style="font-size:0.95rem">Academy</h5>
                    <p style="font-size:0.82rem;color:var(--gray-500)">Bootcamp IT, bimbingan skripsi, dan pelatihan digital untuk talenta Indonesia.</p>
                    <a href="academy/" class="read-more" style="font-size:0.82rem;color:var(--primary);font-weight:600">Selengkapnya <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>


</Layout>
