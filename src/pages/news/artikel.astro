---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Membaca Artikel — SKI News" description="Membaca artikel teknologi terbaru di Sarjana Komputer Indonesia." canonical="https://news.sarjanakomputer.id/artikel" basePath=".." ogTitle="Membaca Artikel — SKI News" ogDescription="Portal berita teknologi terbaru dari CV. Sarjana Komputer Indonesia.">
  <style is:global>
    .article-header {
        padding: 7rem 0 3rem;
        background: linear-gradient(135deg, #0b1120 0%, #1a2a5e 50%, #0b1120 100%);
        position: relative;
    }
    .article-header h1 { color: white; font-size: 2.2rem; font-weight: 800; line-height: 1.3; }
    .article-meta { color: rgba(255,255,255,0.55); font-size: 0.88rem; }
    .article-meta span { margin-right: 1.2rem; }
    .article-body {
        padding: 2.5rem 0 3rem;
        max-width: 800px;
        margin: 0 auto;
    }
    .article-body h1 { font-size: 1.7rem; margin-top: 2rem; font-weight: 700; }
    .article-body h2 { font-size: 1.4rem; margin-top: 1.8rem; font-weight: 700; }
    .article-body h3 { font-size: 1.15rem; margin-top: 1.5rem; font-weight: 600; }
    .article-body p { font-size: 1.02rem; line-height: 1.85; color: #334155; margin-bottom: 1.1rem; }
    .article-body ul, .article-body ol { margin-bottom: 1rem; }
    .article-body li { font-size: 1.02rem; line-height: 1.85; color: #334155; margin-bottom: 0.25rem; }
    .article-body blockquote {
        border-left: 4px solid #312E5F;
        padding: 0.75rem 1.25rem;
        margin: 1.25rem 0;
        background: #f8f9ff;
        border-radius: 0 8px 8px 0;
    }
    .article-body blockquote p { font-style: italic; color: #475569; margin: 0; }
    .article-body code { background: #f1f5f9; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.88rem; color: #dc2626; }
    .article-body pre { background: #0b1120 !important; border-radius: 8px; padding: 1rem; overflow-x: auto; margin: 1.25rem 0; }
    .article-body pre code { background: transparent; color: #e2e8f0; padding: 0; }
    .article-body table { width: 100%; margin: 1.25rem 0; border-collapse: collapse; font-size: 0.92rem; }
    .article-body th, .article-body td { border: 1px solid #e2e8f0; padding: 0.5rem 0.75rem; text-align: left; }
    .article-body th { background: #f8f9ff; font-weight: 600; }
    .article-body img { max-width: 100%; border-radius: 10px; margin: 1rem 0; }
    .article-body a { color: #312E5F; font-weight: 500; }
    .article-loader { text-align: center; padding: 4rem 0; }
    .article-loader .spinner { width: 36px; height: 36px; border: 3px solid #e0e0e0; border-top-color: #312E5F; border-radius: 50%; animation: spin .8s linear infinite; margin: 0 auto 1rem; }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    .category-badge { display: inline-block; padding: 0.25rem 0.8rem; border-radius: 50px; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.75rem; }
    .category-badge.teknologi { background: #dbeafe; color: #1d4ed8; }
    .category-badge.pendidikan { background: #dcfce7; color: #16a34a; }
    .category-badge.bisnis { background: #fef3c7; color: #d97706; }
    .category-badge.startup { background: #f3e8ff; color: #9333ea; }
    .back-btn { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--primary); text-decoration: none; font-weight: 600; font-size: 0.85rem; margin-bottom: 1.5rem; transition: 0.2s; }
    .back-btn:hover { color: var(--secondary); transform: translateX(-4px); }
  </style>

  <section class="section">
    <div class="container" style="max-width:800px">
      <a href="/news" class="back-btn"><i class="bi bi-arrow-left"></i> Kembali ke Berita</a>
    </div>
  </section>

  <section class="article-header">
      <div class="container" style="max-width:800px">
          <div id="articleMeta"></div>
          <h1 id="articleTitle"></h1>
          <div class="article-meta mt-2" id="articleInfo"></div>
      </div>
  </section>

  <section class="article-body" id="articleBody">
      <div class="article-loader" id="articleLoader">
          <div class="spinner"></div>
          <p style="color:#64748b">Memuat artikel...</p>
      </div>
  </section>

  <script src="https://cdn.jsdelivr.net/npm/marked@12.0.1/marked.min.js" is:inline></script>
  <script is:inline>
      (function() {
          var slug = window.location.search.match(/[?&]id=([^&]+)/);
          if (!slug) {
              document.getElementById('articleBody').innerHTML = '<div class="article-loader"><p style="color:#dc2626">Artikel tidak ditemukan. <a href="/news">Kembali ke berita</a></p></div>';
              return;
          }
          slug = decodeURIComponent(slug[1]);

          var contentUrl = '/news/content/' + slug + '.md';
          var jsonUrl = '/news/content/content-index.json';

          // Load JSON index to get metadata
          fetch(jsonUrl)
              .then(function(r) { return r.json(); })
              .then(function(items) {
                  var article = items.find(function(i) { return i.slug === slug; });
                  if (article) {
                      document.getElementById('articleTitle').textContent = article.title;

                      var catColors = { 'Teknologi': 'teknologi', 'Pendidikan': 'pendidikan', 'Bisnis': 'bisnis', 'Startup': 'startup' };
                      var catLower = article.category.toLowerCase();
                      var catClass = catColors[article.category] || 'teknologi';
                      var catIcons = { 'teknologi': 'cpu', 'pendidikan': 'book', 'bisnis': 'briefcase', 'startup': 'rocket-takeoff' };
                      var catIcon = catIcons[catLower] || 'newspaper';

                      document.getElementById('articleMeta').innerHTML =
                          '<span class="category-badge ' + catClass + '"><i class="bi bi-' + catIcon + '"></i> ' + article.category + '</span>';

                      var d = new Date(article.date);
                      var months = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
                      var dateStr = d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
                      document.getElementById('articleInfo').innerHTML =
                          '<span><i class="bi bi-calendar3"></i> ' + dateStr + '</span>' +
                          '<span><i class="bi bi-person"></i> ' + article.author + '</span>';
                      document.title = article.title + ' — SKI News';
                  }
              });

          // Load markdown content
          fetch(contentUrl)
              .then(function(r) {
                  if (!r.ok) throw new Error('Not found');
                  return r.text();
              })
              .then(function(md) {
                  var body = md;
                  var fmMatch = md.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
                  if (fmMatch) {
                      body = fmMatch[2];
                  }
                  document.getElementById('articleLoader').style.display = 'none';
                  document.getElementById('articleBody').innerHTML = marked.parse(body);
              })
              .catch(function() {
                  document.getElementById('articleLoader').innerHTML = '<p style="color:#dc2626">Gagal memuat artikel. <a href="/news">Kembali ke berita</a></p>';
              });
      })();
  </script>
</Layout>
