---
import NewsLayout from '../../layouts/NewsLayout.astro';
import { PB_URL } from '../../utils/config.js';
import { getNewsDetailUrl } from '../../utils/routes.js';

const res = await fetch(`${PB_URL}/api/collections/news/records?sort=-date`);
const data = await res.json();
const allNews = data.items || [];

const first = allNews.length > 0 ? allNews[0] : null;
const restNews = allNews;

// Fallback images from Unsplash based on category
const categoryImages = {
  'Teknologi': 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=600&q=80&fit=crop',
  'Pendidikan': 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=600&q=80&fit=crop',
  'Bisnis': 'https://images.unsplash.com/photo-1664575602276-acd073f104c1?w=600&q=80&fit=crop',
  'Startup': 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?w=600&q=80&fit=crop',
};
const defaultImage = 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=600&q=80&fit=crop';

function getNewsImage(item) {
  // Prioritaskan imageUrl dari CMS, fallback ke Unsplash berdasarkan kategori
  if (item.imageUrl && item.imageUrl.startsWith('http')) return item.imageUrl;
  return categoryImages[item.category] || defaultImage;
}

function formatDate(dateStr: string) {
    var d = new Date(dateStr);
    var months = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
    return d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
}
---

<NewsLayout title="News — Portal Berita Teknologi | Sarjana Komputer Indonesia" description="Update teknologi terbaru, tren AI, web development, cybersecurity, cloud computing, dan startup. Portal berita teknologi dari CV. Sarjana Komputer Indonesia." canonical="https://news.sarjanakomputer.id/" basePath=".." ogTitle="News — Portal Berita Teknologi | Sarjana Komputer Indonesia" ogDescription="Portal berita teknologi terbaru — AI, web dev, cybersecurity, cloud, dan startup.">
  <style is:global>
    /* ===== SLIDER HERO — Premium Card Style ===== */
    .slider-hero {
      position: relative;
      width: 100%;
      height: 480px;
      overflow: hidden;
      background: #050a20;
    }
    .slider-hero .slide-track {
      display: flex;
      width: 100%;
      height: 100%;
      transition: transform 0.6s cubic-bezier(0.65, 0, 0.35, 1);
      will-change: transform;
    }
    .slider-hero .slide {
      min-width: 100%;
      height: 100%;
      position: relative;
      flex-shrink: 0;
      display: flex;
      align-items: center;
    }
    .slider-hero .slide-bg {
      position: absolute;
      inset: 0;
    }
    .slider-hero .slide-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .slider-hero .slide-bg .overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(5,10,32,0.88) 0%, rgba(5,10,32,0.35) 45%, rgba(5,10,32,0.65) 100%);
    }
    .slider-hero .slide-bg .overlay::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 55%;
      background: linear-gradient(0deg, #050a20 0%, transparent 100%);
    }
    .slider-hero .slide-inner {
      position: relative;
      z-index: 3;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }
    .slider-hero .slide-body {
      max-width: 680px;
    }
    .slider-hero .slide-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: var(--secondary);
      color: #fff;
      padding: 0.2rem 0.85rem;
      border-radius: 50px;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 0.6rem;
    }
    .slider-hero .slide-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 2rem;
      font-weight: 800;
      color: #fff;
      line-height: 1.25;
      margin-bottom: 0.5rem;
      text-shadow: 0 2px 8px rgba(0,0,0,0.25);
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .slider-hero .slide-meta {
      color: rgba(255,255,255,0.55);
      font-size: 0.8rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .slider-hero .slide-meta i { margin-right: 0.25rem; }
    .slider-hero .slide-action {
      margin-top: 0.75rem;
    }
    .slider-hero .slide-action a {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      color: #fff;
      background: rgba(227,56,106,0.15);
      border: 1px solid rgba(227,56,106,0.3);
      padding: 0.35rem 1.1rem;
      border-radius: 50px;
      font-size: 0.78rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.25s;
    }
    .slider-hero .slide-action a:hover {
      background: var(--secondary);
      border-color: var(--secondary);
    }

    /* ===== SLIDER NAV (kanan bawah) ===== */
    .slider-nav {
      position: absolute;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 10;
      display: flex;
      gap: 0.4rem;
    }
    .slider-nav button {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.06);
      color: #fff;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.25s;
      backdrop-filter: blur(6px);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .slider-nav button:hover {
      background: var(--secondary);
      border-color: var(--secondary);
    }

    /* ===== SLIDER DOTS (kiri bawah) ===== */
    .slider-dots {
      position: absolute;
      bottom: 1.65rem;
      left: 1.5rem;
      z-index: 10;
      display: flex;
      gap: 0.4rem;
      align-items: center;
    }
    .slider-dots .dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: rgba(255,255,255,0.25);
      cursor: pointer;
      transition: all 0.35s;
    }
    .slider-dots .dot.active {
      width: 24px;
      border-radius: 4px;
      background: var(--secondary);
    }

    /* ===== THUMBNAIL PREVIEW (samping kanan, tengah) ===== */
    .slider-thumbs {
      position: absolute;
      right: 1.5rem;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .slider-thumbs .thumb-item {
      width: 72px;
      height: 50px;
      border-radius: 6px;
      overflow: hidden;
      border: 2px solid transparent;
      cursor: pointer;
      transition: all 0.35s;
      opacity: 0.45;
      position: relative;
    }
    .slider-thumbs .thumb-item.active {
      border-color: var(--secondary);
      opacity: 1;
      transform: scale(1.08);
      box-shadow: 0 0 16px rgba(227,56,106,0.25);
    }
    .slider-thumbs .thumb-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .slider-thumbs .thumb-item .thumb-num {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.45);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.5rem;
      font-weight: 700;
      color: #fff;
    }
    .slider-thumbs .thumb-item.active .thumb-num {
      background: transparent;
    }

    @media (max-width: 992px) {
      .slider-thumbs { display: none; }
    }
    @media (max-width: 768px) {
      .slider-hero { height: 340px; }
      .slider-hero .slide-title { font-size: 1.3rem; }
      .slider-hero .slide-inner { padding: 0 1rem; }
      .slider-nav { bottom: 1rem; right: 1rem; }
      .slider-nav button { width: 32px; height: 32px; font-size: 0.85rem; }
      .slider-dots { bottom: 1.15rem; left: 1rem; }
      .slider-dots .dot.active { width: 18px; }
    }

    /* Category Buttons */
    .category-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
        margin-top: -2.5rem;
        position: relative;
        z-index: 10;
    }
    .cat-btn {
        background: var(--white);
        border: 1px solid var(--gray-100);
        padding: 0.6rem 1.4rem;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--gray-600);
        box-shadow: var(--shadow-sm);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .cat-btn:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow);
        border-color: var(--primary);
        color: var(--primary);
    }
    .cat-btn.active {
        background: var(--primary);
        color: var(--white);
        border-color: var(--primary);
        box-shadow: 0 10px 20px rgba(49, 46, 95, 0.2);
    }

    /* Card Designs */
    .news-grid-container { padding: 4rem 0; }
    
    .news-card-v2 {
        background: var(--white);
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid var(--gray-100);
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        transition: all 0.4s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .news-card-v2 a {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        height: 100%;
    }
    .news-card-v2:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        border-color: rgba(49, 46, 95, 0.1);
    }
    
    .card-img-wrapper {
        position: relative;
        padding-top: 60%;
        overflow: hidden;
        background: #f1f5f9;
    }
    .card-img-wrapper img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }
    .news-card-v2:hover .card-img-wrapper img { transform: scale(1.1); }
    
    .card-badge {
        position: absolute;
        top: 1rem;
        left: 1rem;
        padding: 0.4rem 0.8rem;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(4px);
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 800;
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        z-index: 2;
    }

    .card-content {
        padding: 1.75rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }
    .card-meta {
        font-size: 0.8rem;
        color: var(--gray-400);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .card-title {
        font-size: 1.25rem;
        font-weight: 800;
        line-height: 1.4;
        margin-bottom: 1rem;
        color: var(--dark);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .card-desc {
        font-size: 0.9rem;
        color: var(--gray-500);
        line-height: 1.7;
        margin-bottom: 1.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .card-footer {
        margin-top: auto;
        padding-top: 1.25rem;
        border-top: 1px solid var(--gray-50);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .read-link {
        color: var(--primary);
        font-weight: 700;
        font-size: 0.85rem;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .read-link i { transition: transform 0.2s; }
    .read-link:hover i { transform: translateX(4px); }

    /* Masonry/Featured Section */
    .featured-section { padding-top: 0; }
    .featured-card-v2 {
        background: var(--white);
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid var(--gray-100);
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        height: 100%;
    }
    .featured-card-v2 a {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        height: 100%;
        width: 100%;
    }
    @media (min-width: 992px) {
        .featured-card-v2 a { flex-direction: row; }
        .featured-card-v2 .card-img-wrapper { width: 50%; padding-top: 0; min-height: 400px; }
        .featured-card-v2 .card-content { width: 50%; padding: 3rem; justify-content: center; }
        .featured-card-v2 .card-title { font-size: 2rem; }
    }

    @media (max-width: 768px) {
        .news-hero h1 { font-size: 2.2rem; }
        .news-hero { padding: 6rem 0 4rem; }
    }
  </style>

  <!-- ===== SLIDER HERO ===== -->
  <section class="slider-hero" id="sliderHero">
    <div class="slide-track" id="slideTrack">
      {restNews.slice(0, 5).map((item, i) => (
        <div class="slide">
          <div class="slide-bg">
            <img src={getNewsImage(item)} alt={item.title} />
            <div class="overlay"></div>
          </div>
          <div class="slide-inner">
            <div class="slide-body">
              <span class="slide-badge"><i class={`bi bi-${i === 0 ? 'lightning-fill' : 'fire'}`}></i> {i === 0 ? 'BREAKING' : item.category.toUpperCase()}</span>
              <h2 class="slide-title">{item.title}</h2>
              <div class="slide-meta">
                <span><i class="bi bi-calendar3"></i> {formatDate(item.date)}</span>
                <span><i class="bi bi-person"></i> {item.author || 'Tim SKI'}</span>
              </div>
              <div class="slide-action">
                <a href={getNewsDetailUrl(item.slug)}>Baca Selengkapnya <i class="bi bi-arrow-right"></i></a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Dots -->
    <div class="slider-dots" id="sliderDots">
      {restNews.slice(0, 5).map((_, i) => (
        <span class={"dot" + (i === 0 ? " active" : "")} data-index={i}></span>
      ))}
    </div>

    <!-- Nav Buttons -->
    <div class="slider-nav">
      <button id="prevSlide"><i class="bi bi-chevron-left"></i></button>
      <button id="nextSlide"><i class="bi bi-chevron-right"></i></button>
    </div>

    <!-- Thumbnail Previews -->
    <div class="slider-thumbs" id="sliderThumbs">
      {restNews.slice(0, 5).map((item, i) => (
        <div class={"thumb-item" + (i === 0 ? " active" : "")} data-index={i}>
          <img src={getNewsImage(item)} alt="" />
          <div class="thumb-num">{i === 0 ? '1' : `#${i + 1}`}</div>
        </div>
      ))}
    </div>
  </section>

  <script is:inline>
    (function() {
      var track = document.getElementById('slideTrack');
      if (!track) return;
      var slides = track.children;
      var total = slides.length;
      if (total < 2) return;
      var current = 0;
      var dots = document.querySelectorAll('#sliderDots .dot');
      var thumbs = document.querySelectorAll('#sliderThumbs .thumb-item');
      var interval;

      function goTo(index) {
        if (index < 0) index = total - 1;
        if (index >= total) index = 0;
        current = index;
        track.style.transform = 'translateX(-' + (current * 100) + '%)';
        dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
        thumbs.forEach(function(t, i) { t.classList.toggle('active', i === current); });
      }

      document.getElementById('nextSlide').addEventListener('click', function() { goTo(current + 1); resetAuto(); });
      document.getElementById('prevSlide').addEventListener('click', function() { goTo(current - 1); resetAuto(); });
      dots.forEach(function(d) { d.addEventListener('click', function() { goTo(parseInt(this.dataset.index)); resetAuto(); }); });
      thumbs.forEach(function(t) { t.addEventListener('click', function() { goTo(parseInt(this.dataset.index)); resetAuto(); }); });

      function resetAuto() { clearInterval(interval); interval = setInterval(function() { goTo(current + 1); }, 5000); }
      interval = setInterval(function() { goTo(current + 1); }, 5000);

      // Swipe support
      var startX = 0;
      track.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; });
      track.addEventListener('touchend', function(e) {
        var diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) { diff > 0 ? goTo(current + 1) : goTo(current - 1); resetAuto(); }
      });
    })();
  </script>

  <!-- ===== CATEGORIES ===== -->
  <section class="section" style="padding:0">
      <div class="container">
          <div class="category-nav">
              <button class="cat-btn active" id="btn-all" onclick="filterNews('all')"><i class="bi bi-grid-fill"></i> Semua</button>
              <button class="cat-btn" id="btn-Teknologi" onclick="filterNews('Teknologi')"><i class="bi bi-cpu-fill"></i> Teknologi</button>
              <button class="cat-btn" id="btn-Pendidikan" onclick="filterNews('Pendidikan')"><i class="bi bi-book-fill"></i> Pendidikan</button>
              <button class="cat-btn" id="btn-Bisnis" onclick="filterNews('Bisnis')"><i class="bi bi-briefcase-fill"></i> Karir & Bisnis</button>
              <button class="cat-btn" id="btn-Startup" onclick="filterNews('Startup')"><i class="bi bi-rocket-takeoff-fill"></i> Startup</button>
          </div>
      </div>
  </section>

  <!-- ===== ALL NEWS GRID ===== -->
  <section class="section section-alt news-grid-container">
      <div class="container">
          <div class="d-flex justify-content-between align-items-end mb-5">
              <div>
                  <h2 class="section-title" style="margin:0">Eksplorasi Berita</h2>
                  <p style="color:var(--gray-500);margin:0.25rem 0 0">Arsip lengkap artikel dan publikasi kami</p>
              </div>
          </div>
          <div class="row g-4" id="newsGrid">
            {restNews.map((item) => (
                <div class="col-md-6 col-lg-4 news-item" data-category={item.category}>
                    <div class="news-card-v2">
                        <a href={getNewsDetailUrl(item.slug)}>
                            <div class="card-img-wrapper">
                                <img src={getNewsImage(item)} alt={item.title}>
                                <span class="card-badge">{item.category}</span>
                            </div>
                            <div class="card-content">
                                <div class="card-meta"><i class="bi bi-calendar3"></i> {formatDate(item.date)}</div>
                                <h3 class="card-title">{item.title}</h3>
                                <p class="card-desc">{item.description}</p>
                                <div class="card-footer">
                                    <span class="read-link">Baca Artikel <i class="bi bi-arrow-right"></i></span>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>
            ))}
          </div>
      </div>
  </section>

  <script is:inline>
    function filterNews(cat){
        document.querySelectorAll('.cat-btn').forEach(function(b){ b.classList.remove('active'); });
        var targetId = 'btn-' + (cat === 'all' ? 'all' : cat);
        var btn = document.getElementById(targetId);
        if(btn) btn.classList.add('active');
        
        document.querySelectorAll('.news-item').forEach(function(item){
            var match = cat === 'all' || (item.dataset.category && item.dataset.category.toLowerCase() === cat.toLowerCase());
            item.style.display = match ? 'block' : 'none';
        });
    }
  </script>
</NewsLayout>
