  <!-- ===== SLIDER HERO ===== -->
  <section class="slider-hero" id="sliderHero">
    <div class="slide-track" id="slideTrack">
      {restNews.slice(0, 5).map((item, i) => (
        <div class="slide">
          <div class="slide-bg">
            <img src={getNewsImage(item)} alt={item.title} />
            <div class="overlay"></div>
          </div>
          <div class="slide-inner">
            <div class="slide-body">
              <span class="slide-badge"><i class={`bi bi-${i === 0 ? 'lightning-fill' : 'fire'}`}></i> {i === 0 ? 'BREAKING' : item.category.toUpperCase()}</span>
              <h2 class="slide-title">{item.title}</h2>
              <div class="slide-meta">
                <span><i class="bi bi-calendar3"></i> {formatDate(item.date)}</span>
                <span><i class="bi bi-person"></i> {item.author || 'Tim SKI'}</span>
              </div>
              <div class="slide-action">
                <a href={getNewsDetailUrl(item.slug)}>Baca Selengkapnya <i class="bi bi-arrow-right"></i></a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Dots -->
    <div class="slider-dots" id="sliderDots">
      <div class="dots-inner">
        {restNews.slice(0, 5).map((_, i) => (
          <span class={"dot" + (i === 0 ? " active" : "")} data-index={i}></span>
        ))}
      </div>
    </div>

    <!-- Nav Buttons -->
    <div class="slider-nav">
      <button id="prevSlide"><i class="bi bi-chevron-left"></i></button>
      <button id="nextSlide"><i class="bi bi-chevron-right"></i></button>
    </div>

    <!-- Thumbnail Previews -->
    <div class="slider-thumbs" id="sliderThumbs">
      {restNews.slice(0, 5).map((item, i) => (
        <div class={"thumb-item" + (i === 0 ? " active" : "")} data-index={i}>
          <img src={getNewsImage(item)} alt="" />
          <div class="thumb-num">{i === 0 ? '1' : `#${i + 1}`}</div>
        </div>
      ))}
    </div>
  </section>

  <script is:inline>
    (function() {
      var track = document.getElementById('slideTrack');
      if (!track) return;
      var slides = track.children;
      var total = slides.length;
      if (total < 2) return;
      var current = 0;
      var dots = document.querySelectorAll('#sliderDots .dot');
      var thumbs = document.querySelectorAll('#sliderThumbs .thumb-item');
      var interval;

      function goTo(index) {
        if (index < 0) index = total - 1;
        if (index >= total) index = 0;
        current = index;
        track.style.transform = 'translateX(-' + (current * 100) + '%)';
        dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
        thumbs.forEach(function(t, i) { t.classList.toggle('active', i === current); });
      }

      document.getElementById('nextSlide').addEventListener('click', function() { goTo(current + 1); resetAuto(); });
      document.getElementById('prevSlide').addEventListener('click', function() { goTo(current - 1); resetAuto(); });
      dots.forEach(function(d) { d.addEventListener('click', function() { goTo(parseInt(this.dataset.index)); resetAuto(); }); });
      thumbs.forEach(function(t) { t.addEventListener('click', function() { goTo(parseInt(this.dataset.index)); resetAuto(); }); });

      function resetAuto() { clearInterval(interval); interval = setInterval(function() { goTo(current + 1); }, 5000); }
      interval = setInterval(function() { goTo(current + 1); }, 5000);

      // Swipe support
      var startX = 0;
      track.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; });
      track.addEventListener('touchend', function(e) {
        var diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) { diff > 0 ? goTo(current + 1) : goTo(current - 1); resetAuto(); }
      });
    })();
  </script>

  <!-- ===== CATEGORIES ===== -->
