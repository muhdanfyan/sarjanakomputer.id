  <script is:inline>
    // ===== DATA =====
    var allItems = [];
    document.querySelectorAll('#newsGrid .news-item').forEach(function(el) {
      allItems.push(el);
    });
    var PER_PAGE = 9;
    var currentPage = 1;
    var currentCategory = 'all';

    // ===== FILTER =====
    function filterNews(cat){
        currentCategory = cat;
        currentPage = 1;
        document.querySelectorAll('.cat-card').forEach(function(b){ b.classList.remove('active'); });
        var targetId = 'btn-' + (cat === 'all' ? 'all' : cat);
        var btn = document.getElementById(targetId);
        if(btn) btn.classList.add('active');
        applySearchAndFilter();
    }

    // ===== SEARCH =====
    var searchInput = document.getElementById('searchInput');
    var searchClear = document.getElementById('searchClear');

    if (searchInput) {
      searchInput.addEventListener('input', function() {
        if (searchClear) searchClear.classList.toggle('show', this.value.length > 0);
        currentPage = 1;
        applySearchAndFilter();
      });
    }
    if (searchClear) {
      searchClear.addEventListener('click', function() {
        if (searchInput) {
          searchInput.value = '';
          searchInput.focus();
          searchClear.classList.remove('show');
          currentPage = 1;
          applySearchAndFilter();
        }
      });
    }

    // ===== PAGINATION =====
    function applySearchAndFilter() {
      var query = searchInput ? searchInput.value.toLowerCase().trim() : '';
      var filtered = allItems.filter(function(item) {
        var catMatch = currentCategory === 'all' || (item.dataset.category && item.dataset.category.toLowerCase() === currentCategory.toLowerCase());
        if (!catMatch) return false;
        if (!query) return true;
        var text = item.textContent.toLowerCase();
        return text.indexOf(query) !== -1;
      });

      // pagination
      var totalPages = Math.ceil(filtered.length / PER_PAGE) || 1;
      if (currentPage > totalPages) currentPage = totalPages;
      var start = (currentPage - 1) * PER_PAGE;
      var end = start + PER_PAGE;
      var pageItems = filtered.slice(start, end);

      // show/hide
      allItems.forEach(function(el) { el.style.display = 'none'; });
      pageItems.forEach(function(el) { el.style.display = 'block'; });

      renderPagination(totalPages);
    }

    function renderPagination(totalPages) {
      var wrap = document.getElementById('pagination');
      if (!wrap) return;
      if (totalPages <= 1) { wrap.innerHTML = ''; return; }

      var html = '';
      // prev
      html += '<button class="page-btn" onclick="goPage(' + (currentPage - 1) + ')"' + (currentPage <= 1 ? ' disabled' : '') + '><i class="bi bi-chevron-left"></i></button>';

      var startPage = Math.max(1, currentPage - 2);
      var endPage = Math.min(totalPages, currentPage + 2);
      if (startPage > 1) {
        html += '<button class="page-btn" onclick="goPage(1)">1</button>';
        if (startPage > 2) html += '<span class="page-info">…</span>';
      }
      for (var i = startPage; i <= endPage; i++) {
        html += '<button class="page-btn' + (i === currentPage ? ' active' : '') + '" onclick="goPage(' + i + ')">' + i + '</button>';
      }
      if (endPage < totalPages) {
        if (endPage < totalPages - 1) html += '<span class="page-info">…</span>';
        html += '<button class="page-btn" onclick="goPage(' + totalPages + ')">' + totalPages + '</button>';
      }

      // next
      html += '<button class="page-btn" onclick="goPage(' + (currentPage + 1) + ')"' + (currentPage >= totalPages ? ' disabled' : '') + '><i class="bi bi-chevron-right"></i></button>';

      wrap.innerHTML = html;
    }

    function goPage(page) {
      currentPage = page;
      applySearchAndFilter();
      // scroll to grid
      var grid = document.querySelector('.news-grid-container');
      if (grid) grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  </script>
