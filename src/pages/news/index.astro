---
import NewsLayout from '../../layouts/NewsLayout.astro';
import { PB_URL } from '../../utils/config.js';
import { getNewsDetailUrl } from '../../utils/routes.js';

const res = await fetch(`${PB_URL}/api/collections/news/records?sort=-date`);
const data = await res.json();
const allNews = data.items || [];

const first = allNews.length > 0 ? allNews[0] : null;
const restNews = allNews;

// Fallback images from Unsplash based on category
const categoryImages = {
  'Teknologi': 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=600&q=80&fit=crop',
  'Pendidikan': 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=600&q=80&fit=crop',
  'Bisnis': 'https://images.unsplash.com/photo-1664575602276-acd073f104c1?w=600&q=80&fit=crop',
  'Startup': 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?w=600&q=80&fit=crop',
};
const defaultImage = 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=600&q=80&fit=crop';

function getNewsImage(item) {
  // Prioritaskan imageUrl dari CMS, fallback ke Unsplash berdasarkan kategori
  if (item.imageUrl && item.imageUrl.startsWith('http')) return item.imageUrl;
  return categoryImages[item.category] || defaultImage;
}

function formatDate(dateStr: string) {
    var d = new Date(dateStr);
    var months = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
    return d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
}
---

<NewsLayout title="News — Portal Berita Teknologi | Sarjana Komputer Indonesia" description="Update teknologi terbaru, tren AI, web development, cybersecurity, cloud computing, dan startup. Portal berita teknologi dari CV. Sarjana Komputer Indonesia." canonical="https://news.sarjanakomputer.id/" basePath=".." ogTitle="News — Portal Berita Teknologi | Sarjana Komputer Indonesia" ogDescription="Portal berita teknologi terbaru — AI, web dev, cybersecurity, cloud, dan startup.">
  <style is:global>
    /* ===== SLIDER HERO — Premium Card Style ===== */
    .slider-hero {
      position: relative;
      width: 100%;
      height: 480px;
      overflow: hidden;
      background: #050a20;
    }
    .slider-hero .slide-track {
      display: flex;
      width: 100%;
      height: 100%;
      transition: transform 0.6s cubic-bezier(0.65, 0, 0.35, 1);
      will-change: transform;
    }
    .slider-hero .slide {
      min-width: 100%;
      height: 100%;
      position: relative;
      flex-shrink: 0;
      display: flex;
      align-items: center;
    }
    .slider-hero .slide-bg {
      position: absolute;
      inset: 0;
    }
    .slider-hero .slide-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .slider-hero .slide-bg .overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(5,10,32,0.88) 0%, rgba(5,10,32,0.35) 45%, rgba(5,10,32,0.65) 100%);
    }
    .slider-hero .slide-bg .overlay::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 55%;
      background: linear-gradient(0deg, #050a20 0%, transparent 100%);
    }
    .slider-hero .slide-inner {
      position: relative;
      z-index: 3;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }
    .slider-hero .slide-body {
      max-width: 680px;
    }
    .slider-hero .slide-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: var(--secondary);
      color: #fff;
      padding: 0.2rem 0.85rem;
      border-radius: 50px;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 0.6rem;
    }
    .slider-hero .slide-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 2rem;
      font-weight: 800;
      color: #fff;
      line-height: 1.25;
      margin-bottom: 0.5rem;
      text-shadow: 0 2px 8px rgba(0,0,0,0.25);
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .slider-hero .slide-meta {
      color: rgba(255,255,255,0.55);
      font-size: 0.8rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .slider-hero .slide-meta i { margin-right: 0.25rem; }
    .slider-hero .slide-action {
      margin-top: 0.75rem;
    }
    .slider-hero .slide-action a {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      color: #fff;
      background: rgba(227,56,106,0.15);
      border: 1px solid rgba(227,56,106,0.3);
      padding: 0.35rem 1.1rem;
      border-radius: 50px;
      font-size: 0.78rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.25s;
    }
    .slider-hero .slide-action a:hover {
      background: var(--secondary);
      border-color: var(--secondary);
    }

    /* ===== SLIDER NAV (kanan bawah) ===== */
    .slider-nav {
      position: absolute;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 10;
      display: flex;
      gap: 0.4rem;
    }
    .slider-nav button {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.06);
      color: #fff;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.25s;
      backdrop-filter: blur(6px);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .slider-nav button:hover {
      background: var(--secondary);
      border-color: var(--secondary);
    }

    /* ===== SLIDER DOTS (kiri bawah) ===== */
.slider-dots {
      position: absolute;
      bottom: 1.65rem;
      left: 0;
      right: 0;
      z-index: 10;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }
    .slider-dots .dots-inner {
      display: flex;
      gap: 0.4rem;
      align-items: center;
    }
    .slider-dots .dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #ffffff40;
      cursor: pointer;
      transition: all 0.35s;
    }
    .slider-dots .dot.active {
      width: 24px;
      border-radius: 4px;
      background: var(--secondary);
    }

    /* ===== THUMBNAIL PREVIEW (samping kanan, tengah) ===== */
    .slider-thumbs {
      position: absolute;
      right: 1.5rem;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .slider-thumbs .thumb-item {
      width: 72px;
      height: 50px;
      border-radius: 6px;
      overflow: hidden;
      border: 2px solid transparent;
      cursor: pointer;
      transition: all 0.35s;
      opacity: 0.45;
      position: relative;
    }
    .slider-thumbs .thumb-item.active {
      border-color: var(--secondary);
      opacity: 1;
      transform: scale(1.08);
      box-shadow: 0 0 16px rgba(227,56,106,0.25);
    }
    .slider-thumbs .thumb-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .slider-thumbs .thumb-item .thumb-num {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.45);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.5rem;
      font-weight: 700;
      color: #fff;
    }
    .slider-thumbs .thumb-item.active .thumb-num {
      background: transparent;
    }

    @media (max-width: 992px) {
      .slider-thumbs { display: none; }
    }
    @media (max-width: 768px) {
      .slider-hero {
        height: auto;
        aspect-ratio: 16 / 9;
        max-height: 340px;
        min-height: 220px;
        width: 100vw;
        max-width: 100%;
      }
      .slider-hero .slide-track,
      .slider-hero .slide {
        width: 100vw;
        max-width: 100%;
      }
      .slider-hero .slide-title { font-size: 1.1rem; -webkit-line-clamp: 2; }
      .slider-hero .slide-inner { padding: 0 1rem; }
      .slider-hero .slide-badge { font-size: 0.6rem; padding: 0.15rem 0.65rem; margin-bottom: 0.35rem; }
      .slider-hero .slide-meta { font-size: 0.7rem; gap: 0.6rem; }
      .slider-hero .slide-action { display: none; }
      .slider-nav { bottom: 0.75rem; right: 0.75rem; }
      .slider-nav button { width: 28px; height: 28px; font-size: 0.75rem; }
      .slider-dots { bottom: 0.85rem; padding: 0 0.75rem; }
      .slider-dots .dot.active { width: 16px; }
      /* gradient overlay di HP biar teks kebaca dengan background terang */
      .slider-hero .slide-bg .overlay {
        background: linear-gradient(135deg, rgba(5,10,32,0.75) 0%, rgba(5,10,32,0.2) 50%, rgba(5,10,32,0.6) 100%);
      }
    }

    /* ===== CATEGORY CARDS (horizontal, kotak2 dipercantik) ===== */
    .category-section {
      padding: 1.25rem 0 1.5rem;
      background: var(--gray-50);
    }
    .category-nav-wrap {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.85rem;
    }
    .cat-card {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--white);
      border: 1px solid var(--gray-100);
      padding: 0.7rem 1.2rem;
      border-radius: 12px;
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--gray-600);
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      position: relative;
      overflow: hidden;
    }
    .cat-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 12px;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .cat-card .cat-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      flex-shrink: 0;
      transition: all 0.3s;
    }
    .cat-card .cat-icon.semua { background: linear-gradient(135deg, #312E5F 0%, #E3386A 100%); color: #fff; }
    .cat-card .cat-icon.teknologi { background: #312E5F; color: #fff; }
    .cat-card .cat-icon.pendidikan { background: #0ea5e9; color: #fff; }
    .cat-card .cat-icon.bisnis { background: #059669; color: #fff; }
    .cat-card .cat-icon.startup { background: #f59e0b; color: #fff; }
    .cat-card .cat-label {
      display: flex;
      flex-direction: column;
      line-height: 1.2;
    }
    .cat-card .cat-label .cat-name {
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--gray-700);
      transition: color 0.3s;
    }
    .cat-card .cat-label .cat-count {
      font-size: 0.6rem;
      font-weight: 500;
      color: var(--gray-400);
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }
    .cat-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(49,46,95,0.12);
      border-color: var(--primary);
    }
    .cat-card:hover .cat-name { color: var(--primary); }
    .cat-card.active {
      background: var(--primary);
      border-color: var(--primary);
      box-shadow: 0 8px 24px rgba(49,46,95,0.25);
    }
    .cat-card.active .cat-name { color: #fff; }
    .cat-card.active .cat-count { color: rgba(255,255,255,0.65); }
    .cat-card.active .cat-icon {
      background: rgba(255,255,255,0.2) !important;
      color: #fff !important;
    }
    @media (max-width: 768px) {
      .cat-card {
        padding: 0.55rem 0.9rem;
        gap: 0.45rem;
        border-radius: 10px;
      }
      .cat-card .cat-icon {
        width: 26px;
        height: 26px;
        font-size: 0.7rem;
        border-radius: 6px;
      }
      .cat-card .cat-label .cat-name { font-size: 0.72rem; }
      .cat-card .cat-label .cat-count { font-size: 0.5rem; }
    }

    /* Card Designs */
    .news-grid-container { padding: 4rem 0; }
    
    .news-card-v2 {
        background: var(--white);
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid var(--gray-100);
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        transition: all 0.4s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .news-card-v2 a {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        height: 100%;
    }
    .news-card-v2:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        border-color: rgba(49, 46, 95, 0.1);
    }
    
    .card-img-wrapper {
        position: relative;
        padding-top: 60%;
        overflow: hidden;
        background: #f1f5f9;
    }
    .card-img-wrapper img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }
    .news-card-v2:hover .card-img-wrapper img { transform: scale(1.1); }
    
    .card-badge {
        position: absolute;
        top: 1rem;
        left: 1rem;
        padding: 0.4rem 0.8rem;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(4px);
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 800;
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        z-index: 2;
    }

    .card-content {
        padding: 1.75rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }
    .card-meta {
        font-size: 0.8rem;
        color: var(--gray-400);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .card-title {
        font-size: 1.25rem;
        font-weight: 800;
        line-height: 1.4;
        margin-bottom: 1rem;
        color: var(--dark);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .card-desc {
        font-size: 0.9rem;
        color: var(--gray-500);
        line-height: 1.7;
        margin-bottom: 1.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .card-footer {
        margin-top: auto;
        padding-top: 1.25rem;
        border-top: 1px solid var(--gray-50);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .read-link {
        color: var(--primary);
        font-weight: 700;
        font-size: 0.85rem;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .read-link i { transition: transform 0.2s; }
    .read-link:hover i { transform: translateX(4px); }

    /* Masonry/Featured Section */
    .featured-section { padding-top: 0; }
    .featured-card-v2 {
        background: var(--white);
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid var(--gray-100);
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        height: 100%;
    }
    .featured-card-v2 a {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        height: 100%;
        width: 100%;
    }
    @media (min-width: 992px) {
        .featured-card-v2 a { flex-direction: row; }
        .featured-card-v2 .card-img-wrapper { width: 50%; padding-top: 0; min-height: 400px; }
        .featured-card-v2 .card-content { width: 50%; padding: 3rem; justify-content: center; }
        .featured-card-v2 .card-title { font-size: 2rem; }
    }

    @media (max-width: 768px) {
        .news-hero h1 { font-size: 2.2rem; }
        .news-hero { padding: 6rem 0 4rem; }
        .category-section { padding: 1rem 0 0.75rem; }
        .category-nav-wrap { gap: 0.5rem; }
    }

    /* ===== RESPONSIVE HP: thumbnail kiri, teks kanan ===== */
    @media (max-width: 767px) {
      .news-grid-container { padding: 1rem 0; }
      .news-grid-container .section-title { font-size: 1.1rem; }
      .news-grid-container .mb-5 { margin-bottom: 0.75rem !important; }
      .news-card-v2 {
        border-radius: 12px;
        margin-bottom: 0.25rem;
      }
      .news-card-v2 a {
        flex-direction: row !important;
        align-items: flex-start;
        gap: 0;
      }
      .news-card-v2 .card-img-wrapper {
        width: 100px;
        min-width: 100px;
        height: 80px;
        padding-top: 0 !important;
        border-radius: 10px;
        margin: 0.65rem 0 0.65rem 0.65rem;
        overflow: hidden;
        flex-shrink: 0;
      }
      .news-card-v2 .card-img-wrapper img {
        position: relative;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .news-card-v2 .card-img-wrapper .card-badge {
        display: none;
      }
      .news-card-v2 .card-content {
        padding: 0.65rem 0.75rem;
        flex: 1;
        min-width: 0;
      }
      .news-card-v2 .card-meta {
        font-size: 0.65rem;
        margin-bottom: 0.25rem;
      }
      .news-card-v2 .card-title {
        font-size: 0.82rem;
        margin-bottom: 0.15rem;
        -webkit-line-clamp: 2;
      }
      .news-card-v2 .card-desc,
      .news-card-v2 .card-footer {
        display: none;
      }
      /* separator antar item */
      .news-item {
        padding-bottom: 0 !important;
      }
      .news-item + .news-item .news-card-v2 {
        border-top: 1px solid var(--gray-100);
        border-radius: 0;
      }
      .news-item:first-child .news-card-v2 {
        border-radius: 12px;
      }
      .news-item:last-child .news-card-v2 {
        border-bottom: 1px solid var(--gray-100);
      }
    }

    /* ===== SEARCH BAR ===== */
    .search-section {
      padding: 1.5rem 0;
      background: var(--white);
      border-bottom: 1px solid var(--gray-100);
    }
    .search-wrap {
      position: relative;
      max-width: 500px;
      margin: 0 auto;
    }
    .search-wrap input {
      width: 100%;
      padding: 0.7rem 1rem 0.7rem 2.5rem;
      border: 2px solid var(--gray-100);
      border-radius: 12px;
      font-size: 0.85rem;
      font-family: Inter, sans-serif;
      color: var(--gray-700);
      background: var(--gray-50);
      transition: all 0.25s;
      outline: none;
    }
    .search-wrap input:focus {
      border-color: var(--primary);
      background: var(--white);
      box-shadow: 0 0 0 3px rgba(49,46,95,0.08);
    }
    .search-wrap input::placeholder { color: var(--gray-400); }
    .search-wrap .search-icon {
      position: absolute;
      left: 0.85rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--gray-400);
      font-size: 1rem;
    }
    .search-wrap .search-clear {
      position: absolute;
      right: 0.75rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--gray-400);
      font-size: 0.85rem;
      cursor: pointer;
      display: none;
      background: none;
      border: none;
      padding: 0.25rem;
    }
    .search-wrap .search-clear.show { display: block; }

    /* ===== VIRAL MINGGU INI — Layout Unik ===== */
    .viral-section {
      padding: 3rem 0;
      background: linear-gradient(180deg, var(--white) 0%, #fef2f2 100%);
      border-top: 3px solid var(--secondary);
      border-bottom: 1px solid rgba(227,56,106,0.1);
    }
    .viral-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 2rem;
    }
    .viral-header-left {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .viral-header-left .viral-icon {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, #E3386A, #f43f5e);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 1.2rem;
    }
    .viral-header-left h2 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--dark);
      margin: 0;
    }
    .viral-header-left h2 span { color: var(--secondary); }
    .viral-header-left p {
      margin: 0;
      font-size: 0.78rem;
      color: var(--gray-500);
    }
    .viral-badge-minggu {
      background: var(--secondary);
      color: #fff;
      padding: 0.2rem 0.8rem;
      border-radius: 50px;
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .viral-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .viral-card {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
      background: var(--white);
      border: 1px solid rgba(227,56,106,0.1);
      box-shadow: 0 4px 20px rgba(227,56,106,0.06);
      transition: all 0.35s;
      cursor: pointer;
    }
    .viral-card a {
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .viral-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(227,56,106,0.12);
      border-color: rgba(227,56,106,0.3);
    }
    .viral-card:first-child {
      grid-column: 1 / -1;
    }
    .viral-card:first-child .viral-card-inner {
      display: flex;
