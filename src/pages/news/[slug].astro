---
import { marked } from 'marked';
import NewsLayout from '../../layouts/NewsLayout.astro';
import { PB_URL } from '../../utils/config.js';
import { getNewsUrl, getNewsDetailUrl } from '../../utils/routes.js';

const { slug } = Astro.params;
let news = null;
let popularNews = [];
try {
  const controller = new AbortController();
  const timeoutId = setTimeout(() => controller.abort(), 5000);
  const res = await fetch(`${PB_URL}/api/collections/news/records?filter=(slug='${slug}')&limit=1`, { signal: controller.signal });
  clearTimeout(timeoutId);
  const data = await res.json();
  news = data.items && data.items[0];
} catch (e) {
  console.error("Fetch news detail failed:", e);
}

if (!news) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

// Fetch berita populer (kategori sama, kecuali artikel ini)
try {
  const cat = news.category || '';
  const popRes = await fetch(`${PB_URL}/api/collections/news/records?sort=-date&filter=(category='${cat}')&perPage=5`);
  const popData = await popRes.json();
  popularNews = (popData.items || []).filter((n: any) => n.id !== news.id).slice(0, 5);
} catch (e) {
  // fallback
}

const { title, date, category, author, content, description } = news;

const rawContent = content || '';
const contentSafe = rawContent.length > 10000 ? rawContent.substring(0, 10000) : rawContent;

const htmlContent = (function() {
  try {
    marked.setOptions({
      breaks: true,
      gfm: true
    });
    return marked.parse(contentSafe);
  } catch(e) {
    return '<p>' + contentSafe.replace(/</g, '&lt;').replace(/\n/g, '<br>') + '</p>';
  }
})();

function formatDate(dateStr: string) {
    var d = new Date(dateStr);
    var months = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
    return d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
}

const catColors: Record<string, string> = { 'Teknologi': 'teknologi', 'Pendidikan': 'pendidikan', 'Bisnis': 'bisnis', 'Startup': 'startup' };
const catClass = catColors[category] || 'teknologi';
const catIcons: Record<string, string> = { 'teknologi': 'cpu', 'pendidikan': 'book', 'bisnis': 'briefcase', 'startup': 'rocket-takeoff' };
const catIcon = catIcons[catClass] || 'newspaper';

// Image URL
const categoryImages: Record<string, string> = {
  'Teknologi': 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=1200&q=80&fit=crop',
  'Pendidikan': 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=1200&q=80&fit=crop',
  'Bisnis': 'https://images.unsplash.com/photo-1664575602276-acd073f104c1?w=1200&q=80&fit=crop',
  'Startup': 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?w=1200&q=80&fit=crop',
};
const defaultImage = 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=1200&q=80&fit=crop';
const ogImageRaw = news.image 
  ? (news.image.startsWith('http') ? news.image : `${PB_URL}/api/files/news/${news.id}/${news.image}`) 
  : (news.imageUrl || categoryImages[category] || defaultImage);
const ogImage = (ogImageRaw && ogImageRaw.startsWith && ogImageRaw.startsWith('http')) 
  ? ogImageRaw 
  : (ogImageRaw ? ogImageRaw.split('?')[0] + '?w=1200' : defaultImage);

function getNewsImage(item: any) {
  if (item.image) {
    if (item.image.startsWith('http')) return item.image;
    return `${PB_URL}/api/files/news/${item.id}/${item.image}`;
  }
  if (item.imageUrl && item.imageUrl.startsWith('http')) return item.imageUrl;
  return categoryImages[item.category] || defaultImage;
}

const categories = [
  { name: 'Teknologi', slug: 'teknologi', icon: 'cpu', color: '#3b82f6' },
  { name: 'Pendidikan', slug: 'pendidikan', icon: 'book', color: '#16a34a' },
  { name: 'Bisnis', slug: 'bisnis', icon: 'briefcase', color: '#d97706' },
  { name: 'Startup', slug: 'startup', icon: 'rocket-takeoff', color: '#9333ea' },
];
---

<NewsLayout title={`${title} — SKI News`} description={description || `Membaca artikel teknologi terbaru di Sarjana Komputer Indonesia.`} canonical={getNewsDetailUrl(news.slug)} basePath="../.." ogTitle={`${title} — SKI News`} ogDescription={description} ogImage={ogImage}
  article={{
    type: 'NewsArticle',
    headline: title,
    description: description || '',
    image: ogImage,
    datePublished: date,
    dateModified: date,
    author: author || 'Tim SKI',
    url: getNewsDetailUrl(news.slug)
  }}
>
  <style is:global>
    /* ===== HERO COMPACT ===== */
    .detail-hero {
        position: relative;
        overflow: hidden;
    }
    .detail-hero .hero-bg {
        width: 100%;
        height: 380px;
        object-fit: cover;
        display: block;
    }
    .detail-hero .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(5,10,32,0.3) 0%, rgba(5,10,32,0.85) 70%, #050a20 100%);
    }
    .detail-hero .hero-text {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 2rem 0;
    }
    .detail-hero .hero-text .container {
        max-width: 1200px;
    }
    .detail-hero .hero-text h1 {
        color: #ffffff;
        font-size: 2rem;
        font-weight: 800;
        line-height: 1.25;
        margin: 0.5rem 0 0.75rem;
        max-width: 800px;
    }
    .detail-hero .hero-text .meta {
        color: rgba(255,255,255,0.6);
        font-size: 0.85rem;
    }
    .detail-hero .hero-text .meta span {
        margin-right: 1.2rem;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
    }
    .detail-hero .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: rgba(255,255,255,0.5);
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 600;
        transition: 0.2s;
        margin-bottom: 0.5rem;
    }
    .detail-hero .back-link:hover {
        color: #ffffff;
    }

    /* ===== CATEGORY BADGE ===== */
    .cat-badge {
        display: inline-block;
        padding: 0.25rem 0.8rem;
        border-radius: 50px;
        font-size: 0.72rem;
        font-weight: 700;
    }
    .cat-badge.teknologi { background: rgba(59,130,246,0.2); color: #93c5fd; }
    .cat-badge.pendidikan { background: rgba(22,163,74,0.2); color: #86efac; }
    .cat-badge.bisnis { background: rgba(217,119,6,0.2); color: #fcd34d; }
    .cat-badge.startup { background: rgba(147,51,234,0.2); color: #c4b5fd; }

    /* ===== LAYOUT 2 KOLOM ===== */
    .detail-layout {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 2.5rem;
    }
    .detail-main {
      min-width: 0;
    }
    .detail-sidebar {
      position: sticky;
      top: 5rem;
      align-self: start;
    }

    /* ===== BODY ===== */
    .article-body {
        padding: 1.5rem 0 3rem;
    }
    .article-body h1 { font-size: 1.6rem; margin-top: 2rem; margin-bottom: 1rem; font-weight: 700; color: #1a1838; line-height: 1.4; }
    .article-body h2 { font-size: 1.35rem; margin-top: 1.75rem; margin-bottom: 0.8rem; font-weight: 700; color: #1a1838; line-height: 1.4; }
    .article-body h3 { font-size: 1.15rem; margin-top: 1.5rem; margin-bottom: 0.6rem; font-weight: 600; color: #1a1838; line-height: 1.4; }
    .article-body p { 
        font-size: 1.05rem; 
        line-height: 1.85; 
        color: #334155; 
        margin-bottom: 1.5rem;
        text-align: justify;
    }
    .article-body ul, .article-body ol { margin-bottom: 1.5rem; padding-left: 1.5rem; }
    .article-body li { font-size: 1.05rem; line-height: 1.85; color: #334155; margin-bottom: 0.5rem; text-align: justify; }
    .article-body blockquote {
        border-left: 4px solid var(--secondary);
        padding: 1rem 1.5rem;
        margin: 1.5rem 0;
        background: #fdf2f5;
        border-radius: 0 12px 12px 0;
    }
    .article-body blockquote p { font-style: italic; color: #475569; margin: 0; }
    .article-body code { background: #f1f5f9; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.88rem; color: #dc2626; }
    .article-body pre { background: #0b1120 !important; border-radius: 8px; padding: 1rem; overflow-x: auto; margin: 1.25rem 0; }
    .article-body pre code { background: transparent; color: #e2e8f0; padding: 0; }
    .article-body table { width: 100%; margin: 1.25rem 0; border-collapse: collapse; font-size: 0.92rem; }
    .article-body th, .article-body td { border: 1px solid #e2e8f0; padding: 0.5rem 0.75rem; text-align: left; }
    .article-body th { background: #f8f9ff; font-weight: 600; }
    .article-body img { max-width: 100%; border-radius: 10px; margin: 1rem 0; }
    .article-body a { color: #312E5F; font-weight: 500; text-decoration: underline; }

    /* ===== SIDEBAR WIDGETS ===== */
    .sidebar-widget {
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      padding: 1.25rem;
      margin-bottom: 1.25rem;
    }
    .sidebar-widget .widget-title {
      font-size: 0.85rem;
      font-weight: 800;
      color: #1a1838;
      margin: 0 0 1rem;
      padding-bottom: 0.6rem;
      border-bottom: 2px solid #312E5F;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .sidebar-widget .widget-title i { color: #E3386A; }

    /* Popular item */
    .popular-item {
      display: flex;
      gap: 0.75rem;
      padding: 0.6rem 0;
      border-bottom: 1px solid #f1f5f9;
      text-decoration: none;
    }
    .popular-item:last-child { border-bottom: none; }
    .popular-item:hover { opacity: 0.8; }
    .popular-item .num {
      width: 24px;
      height: 24px;
      background: #f1f5f9;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      font-weight: 700;
      color: #312E5F;
      flex-shrink: 0;
      margin-top: 0.1rem;
    }
    .popular-item .num.top { background: #312E5F; color: #fff; }
    .popular-item .pop-content { flex: 1; min-width: 0; }
    .popular-item .pop-content h4 {
      font-size: 0.8rem;
      font-weight: 600;
      color: #1a1838;
      margin: 0 0 0.2rem;
      line-height: 1.3;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .popular-item .pop-content .pop-meta {
      font-size: 0.68rem;
      color: #94a3b8;
    }

    /* Kategori chips */
    .cat-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .cat-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.4rem 0.85rem;
      border-radius: 50px;
      font-size: 0.75rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s;
    }
    .cat-chip:hover { transform: translateY(-1px); }
    .cat-chip.teknologi { background: rgba(59,130,246,0.1); color: #2563eb; }
    .cat-chip.pendidikan { background: rgba(22,163,74,0.1); color: #16a34a; }
    .cat-chip.bisnis { background: rgba(217,119,6,0.1); color: #d97706; }
    .cat-chip.startup { background: rgba(147,51,234,0.1); color: #9333ea; }

    /* ===== AFFILIATE BANNER ===== */
    .aff-banner {
      padding: 0 0 2rem;
    }
    .aff-banner-inner {
      background: linear-gradient(135deg, #312E5F 0%, #E3386A 100%);
      border-radius: 16px;
      padding: 1.5rem 2rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
      color: #fff;
      box-shadow: 0 8px 30px rgba(227,56,106,0.2);
    }
    .aff-banner-icon {
      width: 52px; height: 52px;
      background: rgba(255,255,255,0.15);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      flex-shrink: 0;
    }
    .aff-banner-text { flex: 1; }
    .aff-banner-text h3 { font-size: 1rem; font-weight: 700; margin: 0 0 0.2rem; color: #fff; }
    .aff-banner-text p { font-size: 0.8rem; color: rgba(255,255,255,0.8); margin: 0; }
    .aff-banner-btn {
      background: #fff; color: #312E5F !important; text-decoration: none !important;
      padding: 0.6rem 1.25rem; border-radius: 50px; font-size: 0.8rem; font-weight: 700;
      white-space: nowrap; display: inline-flex; align-items: center; gap: 0.4rem;
      transition: all 0.2s; flex-shrink: 0;
    }
    .aff-banner-btn:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.2); }

    @media (max-width: 768px) {
        .detail-hero .hero-bg { height: 280px; }
        .detail-hero .hero-text h1 { font-size: 1.4rem; }
        .detail-layout {
          grid-template-columns: 1fr;
          padding: 0 1rem;
          gap: 1.5rem;
        }
        .detail-sidebar { position: static; }
        .article-body { padding: 1rem 0 1.5rem; }
        .aff-banner-inner { flex-direction: column; text-align: center; padding: 1.25rem; }
        .aff-banner-btn { width: 100%; justify-content: center; }
        .share-bar-inner { flex-direction: column; gap: 0.75rem; }
        .share-left { width: 100%; justify-content: center; }
        .share-right { width: 100%; }
        .copy-link-btn { width: 100%; justify-content: center; }
    }

    /* ===== SHARE BAR ===== */
    .share-bar {
        padding: 0 0 1.5rem;
    }
    .share-bar-inner {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }
    .share-left {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .share-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #64748b;
        margin-right: 0.25rem;
    }
    .share-btn {
        width: 38px;
        height: 38px;
        border: none;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        color: #fff;
        cursor: pointer;
        transition: all 0.2s;
    }
    .share-btn:hover { transform: translateY(-2px); }
    .share-btn.facebook { background: #1877f2; }
    .share-btn.facebook:hover { box-shadow: 0 4px 12px rgba(24,119,242,0.4); }
    .share-btn.linkedin { background: #0a66c2; }
    .share-btn.linkedin:hover { box-shadow: 0 4px 12px rgba(10,102,194,0.4); }
    .share-btn.instagram { 
        background: radial-gradient(circle at 30% 30%, #fdf497, #fd5949, #d6249f, #285aeb);
    }
    .share-btn.instagram:hover { box-shadow: 0 4px 12px rgba(214,36,159,0.4); }
    .share-btn.whatsapp { background: #25d366; }
    .share-btn.whatsapp:hover { box-shadow: 0 4px 12px rgba(37,211,102,0.4); }
    .share-right {
        flex-shrink: 0;
    }
    .copy-link-btn {
        background: #312E5F;
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 0.55rem 1.2rem;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }
    .copy-link-btn:hover {
        background: #1A1838;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(49,46,95,0.3);
    }
    .copy-link-btn.copied {
        background: #16a34a;
    }
  </style>

  <!-- ===== HERO ===== -->
  <section class="detail-hero">
    <img src={ogImage} alt={title} class="hero-bg" />
    <div class="hero-overlay"></div>
    <div class="hero-text">
      <div class="container">
        <a href={getNewsUrl()} class="back-link"><i class="bi bi-arrow-left"></i> Kembali ke Berita</a>
        <div>
          <span class={`cat-badge ${catClass}`}><i class={`bi bi-${catIcon}`}></i> {category}</span>
        </div>
        <h1>{title}</h1>
        <div class="meta">
          <span><i class="bi bi-calendar3"></i> {formatDate(date)}</span>
          <span><i class="bi bi-person"></i> {author || 'Tim SKI'}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== LAYOUT 2 KOLOM ===== -->
  <div class="detail-layout">
    <!-- MAIN: Artikel -->
    <div class="detail-main">
      <section class="article-body">
          <Fragment set:html={htmlContent} />
      </section>

      <!-- Banner Konsultasi WA -->
      <section class="aff-banner">
        <div class="aff-banner-inner" style="background: linear-gradient(135deg, #128C7E 0%, #25D366 100%); box-shadow: 0 8px 30px rgba(37,211,102,0.2);">
          <div class="aff-banner-icon"><i class="bi bi-whatsapp"></i></div>
          <div class="aff-banner-text">
            <h3>Butuh Solusi IT Profesional?</h3>
            <p>Diskusikan kebutuhan pembuatan website, aplikasi, atau sistem IT bisnis Anda langsung dengan tim ahli kami.</p>
          </div>
          <a href="https://wa.me/6282299882200" class="aff-banner-btn" target="_blank" rel="noopener noreferrer" style="color: #128C7E !important;">
            <i class="bi bi-whatsapp"></i> Hubungi via WhatsApp
          </a>
        </div>
      </section>

      <!-- Share Bar -->
      <section class="share-bar">
        <div class="share-bar-inner">
          <div class="share-left">
            <span class="share-label">Bagikan</span>
            <button class="share-btn facebook" onclick="shareFacebook()" title="Facebook" aria-label="Bagikan ke Facebook">
              <i class="bi bi-facebook"></i>
            </button>
            <button class="share-btn linkedin" onclick="shareLinkedIn()" title="LinkedIn" aria-label="Bagikan ke LinkedIn">
              <i class="bi bi-linkedin"></i>
            </button>
            <button class="share-btn instagram" onclick="shareInstagram()" title="Instagram Story" aria-label="Bagikan ke Instagram">
              <i class="bi bi-instagram"></i>
            </button>
            <button class="share-btn whatsapp" onclick="shareWhatsApp()" title="WhatsApp Status" aria-label="Bagikan ke WhatsApp">
              <i class="bi bi-whatsapp"></i>
            </button>
          </div>
          <div class="share-right">
            <button class="copy-link-btn" onclick="copyArticleLink()" id="copyLinkBtn" title="Salin Tautan" aria-label="Salin tautan artikel">
              <i class="bi bi-link-45deg" id="copyLinkIcon"></i>
              <span id="copyLinkText">Salin Tautan</span>
            </button>
          </div>
        </div>
      </section>
    </div>

    <!-- SIDEBAR: Populer + Kategori -->
    <aside class="detail-sidebar">
      <!-- Populer -->
      <div class="sidebar-widget">
        <h3 class="widget-title"><i class="bi bi-fire"></i> Berita Populer</h3>
        {popularNews.length > 0 ? (
          popularNews.map((item: any, i: number) => (
            <a href={getNewsDetailUrl(item.slug)} class="popular-item">
              <span class={`num ${i < 3 ? 'top' : ''}`}>{i + 1}</span>
              <div class="pop-content">
                <h4>{item.title}</h4>
                <span class="pop-meta">{item.category} · {formatDate(item.date)}</span>
              </div>
            </a>
          ))
        ) : (
          <p style="font-size:0.82rem;color:#94a3b8;margin:0;">Belum ada berita terkait.</p>
        )}
      </div>

      <!-- Kategori -->
      <div class="sidebar-widget">
        <h3 class="widget-title"><i class="bi bi-grid"></i> Kategori</h3>
        <div class="cat-chips">
          {categories.map((cat) => (
            <a href={`https://news.sarjanakomputer.id/kategori/${cat.slug}`} class={`cat-chip ${cat.slug}`}>
              <i class={`bi bi-${cat.icon}`}></i> {cat.name}
            </a>
          ))}
        </div>
      </div>
    </aside>
  </div>
  <script is:inline>
    (function() {
      var ARTICLE_URL = window.location.href;

      // ===== 1. COPY INTERCEPTOR =====
      document.addEventListener('copy', function(e) {
        // Only intercept if selection is inside article body
        var selection = window.getSelection();
        if (!selection || !selection.toString().trim()) return;

        var selText = selection.toString().trim();
        if (selText.length < 20) return; // ignore very short selections

        var articleBody = document.querySelector('.article-body');
        if (!articleBody || !articleBody.contains(selection.anchorNode)) return;

        // Build new clipboard content: original text + link
        var appended = selText + '\n\n📖 Lihat selengkapnya: ' + ARTICLE_URL;
        e.clipboardData.setData('text/plain', appended);
        e.clipboardData.setData('text/html', selText.replace(/\n/g, '<br>') + '<br><br><a href="' + ARTICLE_URL + '">📖 Lihat selengkapnya</a>');
        e.preventDefault();
      });

      // ===== 2. SHARE FUNCTIONS =====
      window.shareFacebook = function() {
        var url = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(ARTICLE_URL);
        window.open(url, '_blank', 'width=600,height=500');
      };

      window.shareLinkedIn = function() {
        var url = 'https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(ARTICLE_URL);
        window.open(url, '_blank', 'width=600,height=500');
      };

      window.shareInstagram = function() {
        // Instagram Story doesn't have direct web API; open Instagram site
        // User can copy link from there
        var instagramUrl = 'https://www.instagram.com/';
        // Try native share API first (mobile)
        if (navigator.share) {
          navigator.share({
            title: document.title,
            url: ARTICLE_URL
          }).catch(function(){});
        } else {
          window.open(instagramUrl, '_blank');
        }
      };

      window.shareWhatsApp = function() {
        var text = encodeURIComponent(document.title + '\n\n' + ARTICLE_URL);
        // WhatsApp Status doesn't have direct web API
        // Send to chat as fallback — user can forward to status
        var waUrl = 'https://wa.me/?text=' + text;
        // Also try native share for mobile (which offers WhatsApp Status)
        if (navigator.share) {
          navigator.share({
            title: document.title,
            text: document.title,
            url: ARTICLE_URL
          }).catch(function(){});
        } else {
          window.open(waUrl, '_blank');
        }
      };

      window.copyArticleLink = function() {
        var btn = document.getElementById('copyLinkBtn');
        var icon = document.getElementById('copyLinkIcon');
        var text = document.getElementById('copyLinkText');

        navigator.clipboard.writeText(ARTICLE_URL).then(function() {
          btn.classList.add('copied');
          icon.className = 'bi bi-check-lg';
          text.textContent = 'Tersalin!';

          setTimeout(function() {
            btn.classList.remove('copied');
            icon.className = 'bi bi-link-45deg';
            text.textContent = 'Salin Tautan';
          }, 2500);
        }).catch(function() {
          // Fallback
          var temp = document.createElement('input');
          temp.value = ARTICLE_URL;
          document.body.appendChild(temp);
          temp.select();
          document.execCommand('copy');
          document.body.removeChild(temp);
          btn.classList.add('copied');
          icon.className = 'bi bi-check-lg';
          text.textContent = 'Tersalin!';
          setTimeout(function() {
            btn.classList.remove('copied');
            icon.className = 'bi bi-link-45deg';
            text.textContent = 'Salin Tautan';
          }, 2500);
        });
      };
    })();
  </script>
</NewsLayout>
