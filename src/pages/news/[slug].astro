---
import { marked } from 'marked';
import NewsLayout from '../../layouts/NewsLayout.astro';
import { PB_URL } from '../../utils/config.js';
import { getNewsUrl, getNewsDetailUrl } from '../../utils/routes.js';

const { slug } = Astro.params;
let news = null;
try {
  const controller = new AbortController();
  const timeoutId = setTimeout(() => controller.abort(), 5000);
  const res = await fetch(`${PB_URL}/api/collections/news/records?filter=(slug='${slug}')&limit=1`, { signal: controller.signal });
  clearTimeout(timeoutId);
  const data = await res.json();
  news = data.items && data.items[0];
} catch (e) {
  console.error("Fetch news detail failed:", e);
}

if (!news) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const { title, date, category, author, content, description } = news;

const rawContent = content || '';
const contentSafe = rawContent.length > 10000 ? rawContent.substring(0, 10000) : rawContent;

const htmlContent = (function() {
  try {
    return marked.parse(contentSafe);
  } catch(e) {
    return '<p>' + contentSafe.replace(/</g, '&lt;') + '</p>';
  }
})();

function formatDate(dateStr: string) {
    var d = new Date(dateStr);
    var months = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
    return d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
}

const catColors: Record<string, string> = { 'Teknologi': 'teknologi', 'Pendidikan': 'pendidikan', 'Bisnis': 'bisnis', 'Startup': 'startup' };
const catClass = catColors[category] || 'teknologi';
const catIcons: Record<string, string> = { 'teknologi': 'cpu', 'pendidikan': 'book', 'bisnis': 'briefcase', 'startup': 'rocket-takeoff' };
const catIcon = catIcons[catClass] || 'newspaper';

// Gunakan imageUrl dari CMS jika ada, fallback ke Unsplash berdasarkan kategori
const categoryImages: Record<string, string> = {
  'Teknologi': 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=1200&q=80&fit=crop',
  'Pendidikan': 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=1200&q=80&fit=crop',
  'Bisnis': 'https://images.unsplash.com/photo-1664575602276-acd073f104c1?w=1200&q=80&fit=crop',
  'Startup': 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?w=1200&q=80&fit=crop',
};
const defaultImage = 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=1200&q=80&fit=crop';
const ogImageRaw = news.imageUrl || categoryImages[category] || defaultImage;
const ogImage = (ogImageRaw && ogImageRaw.startsWith && ogImageRaw.startsWith('http')) 
  ? ogImageRaw 
  : (ogImageRaw ? ogImageRaw.split('?')[0] + '?w=1200' : defaultImage);
---

<NewsLayout title={`${title} — SKI News`} description={description || `Membaca artikel teknologi terbaru di Sarjana Komputer Indonesia.`} canonical={getNewsDetailUrl(news.slug)} basePath="../.." ogTitle={`${title} — SKI News`} ogDescription={description} ogImage={ogImage}
  article={{
    type: 'NewsArticle',
    headline: title,
    description: description || '',
    image: ogImage,
    datePublished: date,
    dateModified: date,
    author: author || 'Tim SKI',
    url: getNewsDetailUrl(news.slug)
  }}
>
  <style is:global>
    /* ===== HERO COMPACT ===== */
    .detail-hero {
        position: relative;
        overflow: hidden;
    }
    .detail-hero .hero-bg {
        width: 100%;
        height: 380px;
        object-fit: cover;
        display: block;
    }
    .detail-hero .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(5,10,32,0.3) 0%, rgba(5,10,32,0.85) 70%, #050a20 100%);
    }
    .detail-hero .hero-text {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 2rem 0;
    }
    .detail-hero .hero-text .container {
        max-width: 800px;
    }
    .detail-hero .hero-text h1 {
        color: #ffffff;
        font-size: 2rem;
        font-weight: 800;
        line-height: 1.25;
        margin: 0.5rem 0 0.75rem;
    }
    .detail-hero .hero-text .meta {
        color: rgba(255,255,255,0.6);
        font-size: 0.85rem;
    }
    .detail-hero .hero-text .meta span {
        margin-right: 1.2rem;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
    }
    .detail-hero .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: rgba(255,255,255,0.5);
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 600;
        transition: 0.2s;
        margin-bottom: 0.5rem;
    }
    .detail-hero .back-link:hover {
        color: #ffffff;
    }

    /* ===== CATEGORY BADGE ===== */
    .cat-badge {
        display: inline-block;
        padding: 0.25rem 0.8rem;
        border-radius: 50px;
        font-size: 0.72rem;
        font-weight: 700;
    }
    .cat-badge.teknologi { background: rgba(59,130,246,0.2); color: #93c5fd; }
    .cat-badge.pendidikan { background: rgba(22,163,74,0.2); color: #86efac; }
    .cat-badge.bisnis { background: rgba(217,119,6,0.2); color: #fcd34d; }
    .cat-badge.startup { background: rgba(147,51,234,0.2); color: #c4b5fd; }

    /* ===== BODY ===== */
    .article-body {
        padding: 1.5rem 0 3rem;
        max-width: 800px;
        margin: 0 auto;
    }
    .article-body h1 { font-size: 1.6rem; margin-top: 1.75rem; margin-bottom: 0.5rem; font-weight: 700; color: #1a1838; }
    .article-body h2 { font-size: 1.3rem; margin-top: 1.5rem; margin-bottom: 0.4rem; font-weight: 700; color: #1a1838; }
    .article-body h3 { font-size: 1.1rem; margin-top: 1.25rem; margin-bottom: 0.3rem; font-weight: 600; color: #1a1838; }
    .article-body p { font-size: 1.02rem; line-height: 1.85; color: #334155; margin-bottom: 1rem; }
    .article-body ul, .article-body ol { margin-bottom: 1rem; padding-left: 1.5rem; }
    .article-body li { font-size: 1rem; line-height: 1.8; color: #334155; margin-bottom: 0.25rem; }
    .article-body blockquote {
        border-left: 4px solid #312E5F;
        padding: 0.75rem 1.25rem;
        margin: 1.25rem 0;
        background: #f8f9ff;
        border-radius: 0 8px 8px 0;
    }
    .article-body blockquote p { font-style: italic; color: #475569; margin: 0; }
    .article-body code { background: #f1f5f9; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.88rem; color: #dc2626; }
    .article-body pre { background: #0b1120 !important; border-radius: 8px; padding: 1rem; overflow-x: auto; margin: 1.25rem 0; }
    .article-body pre code { background: transparent; color: #e2e8f0; padding: 0; }
    .article-body table { width: 100%; margin: 1.25rem 0; border-collapse: collapse; font-size: 0.92rem; }
    .article-body th, .article-body td { border: 1px solid #e2e8f0; padding: 0.5rem 0.75rem; text-align: left; }
    .article-body th { background: #f8f9ff; font-weight: 600; }
    .article-body img { max-width: 100%; border-radius: 10px; margin: 1rem 0; }
    .article-body a { color: #312E5F; font-weight: 500; text-decoration: underline; }

    @media (max-width: 768px) {
        .detail-hero .hero-bg { height: 280px; }
        .detail-hero .hero-text h1 { font-size: 1.4rem; }
        .article-body { padding: 1.25rem 1rem 2.5rem; }
    }
  </style>

  <!-- ===== HERO: COVER + OVERLAY + TEXT ===== -->
  <section class="detail-hero">
    <img src={ogImage} alt={title} class="hero-bg" />
    <div class="hero-overlay"></div>
    <div class="hero-text">
      <div class="container">
        <a href={getNewsUrl()} class="back-link"><i class="bi bi-arrow-left"></i> Kembali ke Berita</a>
        <div>
          <span class={`cat-badge ${catClass}`}><i class={`bi bi-${catIcon}`}></i> {category}</span>
        </div>
        <h1>{title}</h1>
        <div class="meta">
          <span><i class="bi bi-calendar3"></i> {formatDate(date)}</span>
          <span><i class="bi bi-person"></i> {author || 'Tim SKI'}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ARTICLE BODY ===== -->
  <section class="article-body">
      <Fragment set:html={htmlContent} />
  </section>
</NewsLayout>
