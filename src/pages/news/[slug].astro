---
import { marked } from 'marked';
import Layout from '../../layouts/Layout.astro';
import { PB_URL } from '../../utils/config.js';
import { getNewsUrl, getNewsDetailUrl } from '../../utils/routes.js';

const { slug } = Astro.params;
const res = await fetch(`${PB_URL}/api/collections/news/records?filter=(slug='${slug}')&limit=1`);
const data = await res.json();
const news = data.items && data.items[0];

if (!news) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const { title, date, category, author, content, description } = news;

const htmlContent = marked.parse(content || '');

function formatDate(dateStr: string) {
    var d = new Date(dateStr);
    var months = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
    return d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
}

const catColors: Record<string, string> = { 'Teknologi': 'teknologi', 'Pendidikan': 'pendidikan', 'Bisnis': 'bisnis', 'Startup': 'startup' };
const catClass = catColors[category] || 'teknologi';
const catIcons: Record<string, string> = { 'teknologi': 'cpu', 'pendidikan': 'book', 'bisnis': 'briefcase', 'startup': 'rocket-takeoff' };
const catIcon = catIcons[catClass] || 'newspaper';

// Fallback images from Unsplash based on category (same as index)
const categoryImages: Record<string, string> = {
  'Teknologi': 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=1200&q=80&fit=crop',
  'Pendidikan': 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=1200&q=80&fit=crop',
  'Bisnis': 'https://images.unsplash.com/photo-1664575602276-acd073f104c1?w=1200&q=80&fit=crop',
  'Startup': 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?w=1200&q=80&fit=crop',
};
const defaultImage = 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=1200&q=80&fit=crop';
const ogImage = categoryImages[category] || defaultImage;
---

<Layout title={`${title} — SKI News`} description={description || `Membaca artikel teknologi terbaru di Sarjana Komputer Indonesia.`} canonical={getNewsDetailUrl(news.slug)} basePath="../.." ogTitle={`${title} — SKI News`} ogDescription={description} ogImage={ogImage}>
  <style is:global>
    .article-header {
        padding: 7rem 0 3rem;
        background: linear-gradient(135deg, #0b1120 0%, #1a2a5e 50%, #0b1120 100%);
        position: relative;
    }
    .article-header h1 { color: white; font-size: 2.2rem; font-weight: 800; line-height: 1.3; }
    .article-meta { color: rgba(255,255,255,0.55); font-size: 0.88rem; }
    .article-meta span { margin-right: 1.2rem; }
    .article-cover {
        width: 100%;
        max-height: 400px;
        object-fit: cover;
        border-radius: 0;
        display: block;
    }
    .article-body {
        padding: 2.5rem 0 3rem;
        max-width: 800px;
        margin: 0 auto;
    }
    .article-body h1 { font-size: 1.7rem; margin-top: 2rem; font-weight: 700; }
    .article-body h2 { font-size: 1.4rem; margin-top: 1.8rem; font-weight: 700; }
    .article-body h3 { font-size: 1.15rem; margin-top: 1.5rem; font-weight: 600; }
    .article-body p { font-size: 1.02rem; line-height: 1.85; color: #334155; margin-bottom: 1.1rem; }
    .article-body ul, .article-body ol { margin-bottom: 1rem; }
    .article-body li { font-size: 1.02rem; line-height: 1.85; color: #334155; margin-bottom: 0.25rem; }
    .article-body blockquote {
        border-left: 4px solid #312E5F;
        padding: 0.75rem 1.25rem;
        margin: 1.25rem 0;
        background: #f8f9ff;
        border-radius: 0 8px 8px 0;
    }
    .article-body blockquote p { font-style: italic; color: #475569; margin: 0; }
    .article-body code { background: #f1f5f9; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.88rem; color: #dc2626; }
    .article-body pre { background: #0b1120 !important; border-radius: 8px; padding: 1rem; overflow-x: auto; margin: 1.25rem 0; }
    .article-body pre code { background: transparent; color: #e2e8f0; padding: 0; }
    .article-body table { width: 100%; margin: 1.25rem 0; border-collapse: collapse; font-size: 0.92rem; }
    .article-body th, .article-body td { border: 1px solid #e2e8f0; padding: 0.5rem 0.75rem; text-align: left; }
    .article-body th { background: #f8f9ff; font-weight: 600; }
    .article-body img { max-width: 100%; border-radius: 10px; margin: 1rem 0; }
    .article-body a { color: #312E5F; font-weight: 500; }
    
    .category-badge { display: inline-block; padding: 0.25rem 0.8rem; border-radius: 50px; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.75rem; }
    .category-badge.teknologi { background: #dbeafe; color: #1d4ed8; }
    .category-badge.pendidikan { background: #dcfce7; color: #16a34a; }
    .category-badge.bisnis { background: #fef3c7; color: #d97706; }
    .category-badge.startup { background: #f3e8ff; color: #9333ea; }
    .back-btn { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--primary); text-decoration: none; font-weight: 600; font-size: 0.85rem; margin-bottom: 1.5rem; transition: 0.2s; }
    .back-btn:hover { color: var(--secondary); transform: translateX(-4px); }
  </style>

  <!-- Cover Image -->
  <img src={ogImage} alt={title} class="article-cover" />

  <section class="section">
    <div class="container" style="max-width:800px">
      <a href={getNewsUrl()} class="back-btn"><i class="bi bi-arrow-left"></i> Kembali ke Berita</a>
    </div>
  </section>

  <section class="article-header">
      <div class="container" style="max-width:800px">
          <div>
            <span class={`category-badge ${catClass}`}><i class={`bi bi-${catIcon}`}></i> {category}</span>
          </div>
          <h1>{title}</h1>
          <div class="article-meta mt-2">
            <span><i class="bi bi-calendar3"></i> {formatDate(date)}</span>
            <span><i class="bi bi-person"></i> {author || 'Tim SKI'}</span>
          </div>
      </div>
  </section>

  <section class="article-body">
      <Fragment set:html={htmlContent} />
  </section>
</Layout>
