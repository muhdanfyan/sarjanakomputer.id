---
import Layout from '../../layouts/Layout.astro';
import { getHomeUrl } from '../../utils/routes.js';
---

<Layout title="Alat Developer — Sarjana Komputer Indonesia" description="Tools QA dan utility untuk developer — Genesis QA, API testing, security scanner, performance benchmark" canonical="https://sarjanakomputer.id/alat-dev/" basePath=".." ogTitle="Alat Developer — Sarjana Komputer Indonesia" ogDescription="Tools QA dan utility untuk developer — automated testing, API scanner, security audit, performance benchmark.">

  <!-- HERO -->
  <section class="hero-section" style="padding:80px 0 60px">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-8">
          <div class="hero-badge"><i class="bi bi-tools"></i> Alat Developer</div>
          <h1>Tools QA & <span style="background:var(--gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent">Developer Utility</span></h1>
          <p>Kumpulan tools open-source untuk automated testing, API security scanning, performance benchmark, dan monitoring sistem — dikembangkan oleh tim Sarjana Komputer Indonesia.</p>
        </div>
        <div class="col-lg-4 text-center d-none d-lg-block">
          <i class="bi bi-gear-wide-connected" style="font-size:8rem;color:rgba(255,255,255,0.08)"></i>
        </div>
      </div>
    </div>
  </section>

  <!-- GENESIS-QA CARD -->
  <section class="section">
    <div class="container">
      <div class="card" style="background:var(--card-bg);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:40px;margin-bottom:30px;">
        <div class="row align-items-center">
          <div class="col-lg-8">
            <span class="badge" style="background:var(--gradient);color:#fff;padding:6px 16px;border-radius:20px;font-size:0.8rem;margin-bottom:15px;">🇺🇸 OPEN SOURCE</span>
            <h3 style="margin-bottom:8px;">Genesis QA <span style="color:var(--accent);font-weight:300;">v1.0</span></h3>
            <p style="color:rgba(255,255,255,0.6);margin-bottom:8px;">Generic System Integrity Suite — automated QA testing framework</p>
            <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:15px;">
              <span class="badge" style="background:rgba(99,102,241,0.15);color:#818cf8;padding:4px 12px;border-radius:12px;">API Testing</span>
              <span class="badge" style="background:rgba(239,68,68,0.15);color:#f87171;padding:4px 12px;border-radius:12px;">Security Scan</span>
              <span class="badge" style="background:rgba(34,197,94,0.15);color:#4ade80;padding:4px 12px;border-radius:12px;">Performance</span>
              <span class="badge" style="background:rgba(168,85,247,0.15);color:#c084fc;padding:4px 12px;border-radius:12px;">CI/CD</span>
            </div>
            <p style="font-size:0.9rem;color:rgba(255,255,255,0.5);">Scan → Generate → Test → Report → Notify. Pipeline lengkap untuk QA automation: crawler endpoint, security audit, edge case factory, 7 test engines (HTTP, CORS, Auth, Redirect, Security, DB, Performance), report console/JSON/HTML, notifikasi WhatsApp, cron job, GitHub Actions CI/CD.</p>
          </div>
          <div class="col-lg-4 text-center mt-3 mt-lg-0">
            <a href="https://github.com/muhdanfyan/genesis-qa" target="_blank" class="btn-primary-custom" style="display:inline-flex;align-items:center;gap:8px;margin-bottom:10px;">
              <i class="bi bi-github"></i> GitHub Repo
            </a>
            <br>
            <span style="font-size:0.8rem;color:rgba(255,255,255,0.4);">⭐ 96% complete · 97/101 tasks</span>
          </div>
        </div>

        <!-- Stats -->
        <div class="row mt-4 pt-3" style="border-top:1px solid rgba(255,255,255,0.06);">
          <div class="col-4 col-md-2 text-center">
            <div style="font-size:1.5rem;font-weight:700;color:#4ade80;">7</div>
            <div style="font-size:0.75rem;color:rgba(255,255,255,0.4);">Test Engines</div>
          </div>
          <div class="col-4 col-md-2 text-center">
            <div style="font-size:1.5rem;font-weight:700;color:#818cf8;">4</div>
            <div style="font-size:0.75rem;color:rgba(255,255,255,0.4);">Live Systems</div>
          </div>
          <div class="col-4 col-md-2 text-center">
            <div style="font-size:1.5rem;font-weight:700;color:#fbbf24;">5</div>
            <div style="font-size:0.75rem;color:rgba(255,255,255,0.4);">Report Formats</div>
          </div>
          <div class="col-6 col-md-3 text-center mt-2 mt-md-0">
            <div style="font-size:1.5rem;font-weight:700;color:#f87171;">30m</div>
            <div style="font-size:0.75rem;color:rgba(255,255,255,0.4);">Cron Interval</div>
          </div>
          <div class="col-6 col-md-3 text-center mt-2 mt-md-0">
            <div style="font-size:1.5rem;font-weight:700;color:#34d399;">CLI</div>
            <div style="font-size:0.75rem;color:rgba(255,255,255,0.4);">──system ──mode</div>
          </div>
        </div>
      </div>

      <!-- Fitur Details -->
      <div class="row mt-4">
        <div class="col-md-6 mb-3">
          <div class="card h-100" style="background:var(--card-bg);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:24px;">
            <i class="bi bi-search" style="font-size:1.5rem;color:#818cf8;margin-bottom:12px;"></i>
            <h5>Scan Mode</h5>
            <p style="font-size:0.85rem;color:rgba(255,255,255,0.5);margin-bottom:0;">Crawler async, endpoint discovery (100+ wordlist), security audit (headers, info leak, sensitive path, SSL/TLS)</p>
          </div>
        </div>
        <div class="col-md-6 mb-3">
          <div class="card h-100" style="background:var(--card-bg);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:24px;">
            <i class="bi bi-gear" style="font-size:1.5rem;color:#34d399;margin-bottom:12px;"></i>
            <h5>Generate Mode</h5>
            <p style="font-size:0.85rem;color:rgba(255,255,255,0.5);margin-bottom:0;">Scenario generator (5 kategori) + edge case factory (SQLi, XSS, boundary, unicode, path traversal) + OpenAPI parser</p>
          </div>
        </div>
        <div class="col-md-6 mb-3">
          <div class="card h-100" style="background:var(--card-bg);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:24px;">
            <i class="bi bi-lightning" style="font-size:1.5rem;color:#fbbf24;margin-bottom:12px;"></i>
            <h5>Execute Mode</h5>
            <p style="font-size:0.85rem;color:rgba(255,255,255,0.5);margin-bottom:0;">7 test engines: HTTP, CORS, Auth, Redirect, Security, DB, Performance. Retry 3x, timing, redirect chain max 10 hops</p>
          </div>
        </div>
        <div class="col-md-6 mb-3">
          <div class="card h-100" style="background:var(--card-bg);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:24px;">
            <i class="bi bi-bar-chart" style="font-size:1.5rem;color:#f87171;margin-bottom:12px;"></i>
            <h5>Report & Notify</h5>
            <p style="font-size:0.85rem;color:rgba(255,255,255,0.5);margin-bottom:0;">Console warna, JSON, HTML dashboard. Notifikasi WhatsApp via wa-reporter. Cron job tiap 30 menit.</p>
          </div>
        </div>
      </div>

      <!-- Cara Pakai -->
      <div class="mt-4" style="background:rgba(255,255,255,0.03);border-radius:12px;padding:30px;">
        <h5 style="margin-bottom:15px;"><i class="bi bi-terminal" style="margin-right:8px;"></i> Cara Pakai</h5>
        <pre style="background:rgba(0,0,0,0.3);padding:16px;border-radius:8px;font-size:0.8rem;overflow-x:auto;color:#a5f3fc;"><code># Install
pip install requests pyyaml

# Quick test
python run.py --system pisantri --mode execute --output console

# Full pipeline (scan → generate → execute → report)
python run.py --system pisantri --mode full --output html --notify

# Performance test
python run.py --system pisantri --mode performance

# Tambah sistem baru
cp config/systems/_template.yaml config/systems/sistem-ku.yaml
# edit file → python run.py --system sistem-ku --mode execute</code></pre>
      </div>

      <!-- CTA -->
      <div class="text-center mt-5">
        <a href="https://github.com/muhdanfyan/genesis-qa" target="_blank" class="btn-primary-custom" style="display:inline-flex;align-items:center;gap:8px;">
          <i class="bi bi-github"></i> Lihat di GitHub
        </a>
        <p style="font-size:0.8rem;color:rgba(255,255,255,0.4);margin-top:10px;">Open source — kontribusi dan saran terbuka</p>
      </div>
    </div>
  </section>

</Layout>

<style>
  .btn-primary-custom {
    background:var(--gradient);
    color:#fff;
    border:none;
    padding:10px 28px;
    border-radius:8px;
    font-weight:500;
    text-decoration:none;
    transition:opacity 0.2s;
  }
  .btn-primary-custom:hover { opacity:0.9; color:#fff; }
  .hero-badge {
    display:inline-flex;
    align-items:center;
    gap:6px;
    background:rgba(99,102,241,0.15);
    color:#818cf8;
    padding:4px 14px;
    border-radius:20px;
    font-size:0.8rem;
    margin-bottom:12px;
    width:fit-content;
  }
  code {
    color: #a5f3fc;
  }
</style>
