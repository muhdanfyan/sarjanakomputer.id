---
import Layout from '../../layouts/Layout.astro';
export const prerender = true;

const PB_URL = 'http://103.126.117.20:8095';
const res = await fetch(`${PB_URL}/api/collections/profiles/records?limit=1`);
const data = await res.json();
const profile = data.items[0] || {};
profile.email = profile.email_address;
---

<Layout title={`${profile.title} — ${profile.companyName}`} description={`Profil resmi ${profile.companyName} — Solusi IT profesional dari Baubau, Sulawesi Tenggara`} canonical="https://profil.sarjanakomputer.id/profil/" basePath=".." ogTitle={`${profile.title} — ${profile.companyName}`} ogDescription={`Profil resmi ${profile.companyName} — mitra terdepan transformasi digital dan jembatan karier menuju industri global. Solusi IT profesional dari Baubau, Sulawesi Tenggara.`}>
  <!-- HERO -->
  <section class="hero-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-7">
          <div class="hero-badge"><i class="bi bi-building"></i> Profil Perusahaan</div>
          <h1>{profile.companyName}</h1>
          <p>{profile.heroSubtitle}</p>
          <div class="d-flex flex-wrap gap-2 mt-3">
            <a href="#tentang" class="btn-primary-custom"><i class="bi bi-info-circle"></i> Tentang Kami</a>
            <a href="#kontak" class="btn-outline-custom" style="border-color:rgba(255,255,255,0.2);color:rgba(255,255,255,0.7);">Hubungi Kami <i class="bi bi-whatsapp"></i></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TENTANG -->
  <section class="section" id="tentang">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem">
          <i class="bi bi-info-circle"></i> Sekilas
        </div>
        <h2 class="section-title">Tentang Perusahaan</h2>
        <p class="section-subtitle">Bergerak di bidang pengembangan IT, solusi e-government, dan pelatihan SDM digital</p>
      </div>
      <div class="about-grid">
        <div class="about-item"><div class="label">Nama Resmi</div><div class="value">{profile.namaResmi}</div></div>
        <div class="about-item"><div class="label">Bidang Usaha</div><div class="value">{profile.bidangUsaha}</div></div>
        <div class="about-item"><div class="label">Didirikan</div><div class="value">{profile.didirikan}</div></div>
        <div class="about-item"><div class="label">SK Kemenkumham</div><div class="value">{profile.skKemenkumham}</div></div>
        <div class="about-item"><div class="label">NIB</div><div class="value">{profile.nib}</div></div>
        <div class="about-item"><div class="label">NPWP</div><div class="value">{profile.npwp}</div></div>
        <div class="about-item"><div class="label">Lokasi</div><div class="value">{profile.lokasi}</div></div>
        <div class="about-item"><div class="label">Pendiri & Direktur</div><div class="value">{profile.pendiri}</div></div>
        <div class="about-item"><div class="label">Jumlah Personil</div><div class="value">{profile.jumlahPersonil}</div></div>
      </div>
    </div>
  </section>

  <!-- Cross Link -->
  <div class="text-center mt-4">
    <p style="font-size:0.85rem;color:var(--gray-500)">Butuh solusi IT? Lihat <a href="../aplikasi/" style="color:var(--primary);font-weight:600">Layanan Aplikasi</a> · <a href="../academy/" style="color:var(--primary);font-weight:600">Akademi</a> · <a href="../news/" style="color:var(--primary);font-weight:600">Blog Teknologi</a></p>
  </div>

  <!-- VISI MISI -->
  <section class="section section-alt">
    <div class="container">
      <div class="row g-3">
        <div class="col-md-6">
          <div class="card-custom" style="padding:2rem">
            <div class="card-icon" style="background:linear-gradient(135deg,var(--primary),var(--primary-light))"><i class="bi bi-eye"></i></div>
            <h5 style="font-size:1.1rem">Visi</h5>
            <p style="font-size:0.85rem;color:var(--gray-500);line-height:1.8">{profile.visi}</p>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card-custom" style="padding:2rem">
            <div class="card-icon" style="background:linear-gradient(135deg,var(--secondary),#22d3ee)"><i class="bi bi-bullseye"></i></div>
            <h5 style="font-size:1.1rem">Misi</h5>
            <ol style="font-size:0.85rem;color:var(--gray-500);line-height:2;padding-left:1rem;margin:0">
              {profile.misi.map((m: string) => (
                <li>{m}</li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STRUKTUR ORGANISASI -->
  <section class="section" id="struktur">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem">
          <i class="bi bi-diagram-3"></i> Tim Kami
        </div>
        <h2 class="section-title">Struktur Organisasi</h2>
        <p class="section-subtitle">Para profesional di balik {profile.namaResmi}</p>
      </div>
      <div class="team-grid-home">
        {profile.tim.map((t: any) => (
            <div class="team-card-home">
              <img loading="lazy" src={t.image} alt={t.name} class="tch-img">
              <div class="tch-body"><h5>{t.name}</h5><div class="role-badge">{t.role}</div></div>
            </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LEGALITAS -->
  <section class="section section-alt" id="legalitas">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem">
          <i class="bi bi-shield-check"></i> Legalitas
        </div>
        <h2 class="section-title">Dokumen Legal</h2>
        <p class="section-subtitle">Perusahaan berbadan hukum yang terpercaya</p>
      </div>
      <div class="legal-list">
        <div class="legal-item"><i class="bi bi-file-earmark-text"></i><div><div>Akta Pendirian</div><span>{profile.didirikan}</span></div></div>
        <div class="legal-item"><i class="bi bi-shield-check"></i><div><div>SK Kemenkumham</div><span>{profile.skKemenkumham}</span></div></div>
        <div class="legal-item"><i class="bi bi-card-heading"></i><div><div>NIB</div><span>{profile.nib}</span></div></div>
        <div class="legal-item"><i class="bi bi-file-earmark-check"></i><div><div>NPWP</div><span>{profile.npwp}</span></div></div>
      </div>
    </div>
  </section>

  <!-- KBLI -->
  <section class="section" id="kbli">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem">
          <i class="bi bi-list-check"></i> KBLI
        </div>
        <h2 class="section-title">Klasifikasi Baku Lapangan Usaha</h2>
        <p class="section-subtitle">Bidang usaha yang dikelola {profile.namaResmi}</p>
      </div>
      <div class="kbli-grid">
        {profile.kbli.map((k: any) => (
            <div class="kbli-item"><span class="kbli-code">{k.code}</span><div><strong>{k.title}</strong><span>{k.desc}</span></div></div>
        ))}
      </div>
      <div class="text-center mt-3">
        <p style="font-size:0.8rem;color:var(--gray-400)">* KBLI (Klasifikasi Baku Lapangan Usaha Indonesia) — siap didaftarkan ke OSS</p>
      </div>
    </div>
  </section>

  <!-- KLIEN & TESTIMONI -->
  <section class="section" id="klien">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem">
          <i class="bi bi-people"></i> Klien
        </div>
        <h2 class="section-title">Klien & Mitra</h2>
        <p class="section-subtitle">Telah dipercaya oleh berbagai institusi</p>
      </div>
      <div class="row g-2 mb-4">
        <div class="col-4 col-md-2"><div class="client-logo">Diskominfo</div></div>
        <div class="col-4 col-md-2"><div class="client-logo">Dinkes</div></div>
        <div class="col-4 col-md-2"><div class="client-logo">BKD</div></div>
        <div class="col-4 col-md-2"><div class="client-logo">MAN 2</div></div>
        <div class="col-4 col-md-2"><div class="client-logo">Pondok Info</div></div>
        <div class="col-4 col-md-2"><div class="client-logo">Komprog</div></div>
      </div>
      <div class="row g-3">
        <div class="col-md-4">
          <div class="testimoni-card">
            <div class="stars"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i></div>
            <p>"Tim Sarjana Komputer Indonesia sangat profesional dan responsif. Aplikasi yang dibuat sesuai dengan kebutuhan kami."</p>
            <div class="author">— Kepala Dinas</div>
            <div class="position">Instansi Pemerintah</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="testimoni-card">
            <div class="stars"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i></div>
            <p>"Pelayanan maintenance yang cepat dan tanggap. Sistem kami selalu berjalan tanpa kendala berarti."</p>
            <div class="author">— Direktur</div>
            <div class="position">Lembaga Pendidikan</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="testimoni-card">
            <div class="stars"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i></div>
            <p>"Kolaborasi dengan Sarjana Komputer Indonesia sangat menyenangkan. Mereka paham betul kebutuhan IT kami."</p>
            <div class="author">— Ketua</div>
            <div class="position">Komunitas Programmer Baubau</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- KONTAK -->
  <section class="section section-alt" id="kontak">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem">
          <i class="bi bi-envelope"></i> Kontak
        </div>
        <h2 class="section-title">Hubungi Kami</h2>
        <p class="section-subtitle">Ada pertanyaan? Silakan hubungi kami</p>
      </div>
      <div class="row g-3 justify-content-center">
        <div class="col-md-6 col-lg-5">
          <form action="https://formspree.io/f/your-form-id" method="POST" style="display:grid;gap:0.75rem">
            <input class="form-control" type="text" name="nama" placeholder="Nama Lengkap" required style="border-radius:10px;padding:0.65rem 1rem;font-size:0.88rem">
            <input class="form-control" type="email" name="email" placeholder="Email" required style="border-radius:10px;padding:0.65rem 1rem;font-size:0.88rem">
            <input class="form-control" type="text" name="subjek" placeholder="Subjek" style="border-radius:10px;padding:0.65rem 1rem;font-size:0.88rem">
            <textarea class="form-control" name="pesan" rows="4" placeholder="Pesan" required style="border-radius:10px;padding:0.65rem 1rem;font-size:0.88rem"></textarea>
            <button class="btn-primary-custom" type="submit" style="justify-content:center"><i class="bi bi-send"></i> Kirim Pesan</button>
          </form>
        </div>
        <div class="col-md-5 col-lg-4">
          <div style="display:grid;gap:1rem">
            <div class="card-custom d-flex align-items-center gap-3" style="padding:1.25rem">
              <div style="width:44px;height:44px;border-radius:12px;background:rgba(49,46,95,0.08);display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:1.2rem"><i class="bi bi-geo-alt-fill"></i></div>
              <div><div style="font-weight:600;font-size:0.9rem">Alamat</div><div style="font-size:0.82rem;color:var(--gray-500)">{profile.alamat}</div></div>
            </div>
            <div class="card-custom d-flex align-items-center gap-3" style="padding:1.25rem">
              <div style="width:44px;height:44px;border-radius:12px;background:rgba(49,46,95,0.08);display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:1.2rem"><i class="bi bi-envelope-fill"></i></div>
              <div><div style="font-weight:600;font-size:0.9rem">Email</div><div style="font-size:0.82rem;color:var(--gray-500)">{profile.email}</div></div>
            </div>
            <div class="card-custom d-flex align-items-center gap-3" style="padding:1.25rem">
              <div style="width:44px;height:44px;border-radius:12px;background:rgba(49,46,95,0.08);display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:1.2rem"><i class="bi bi-whatsapp"></i></div>
              <div><div style="font-weight:600;font-size:0.9rem">WhatsApp</div><div style="font-size:0.82rem;color:var(--gray-500)"><a href={profile.whatsapp_link} style="color:var(--primary);text-decoration:none">{profile.whatsapp}</a></div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem}
    .about-item{padding:1.5rem;border-radius:var(--radius);background:var(--white);border:1px solid var(--gray-100)}
    .about-item .label{font-size:0.75rem;color:var(--gray-400);text-transform:uppercase;letter-spacing:0.5px;font-weight:600}
    .about-item .value{font-size:1rem;font-weight:600;color:var(--dark);margin-top:0.15rem}
    .legal-list{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .legal-item{display:flex;align-items:center;gap:1rem;padding:1rem;border-radius:var(--radius-sm);background:var(--white);border:1px solid var(--gray-100)}
    .legal-item i{font-size:1.5rem;color:var(--primary)}
    .legal-item div{font-size:0.85rem;font-weight:600;margin-bottom:0.1rem}
    .legal-item span{font-size:0.78rem;color:var(--gray-500)}
    .client-logo{display:flex;align-items:center;justify-content:center;padding:1.5rem;background:var(--white);border-radius:var(--radius);border:1px solid var(--gray-100);height:100px;font-weight:700;color:var(--gray-400);font-size:0.9rem}
    .testimoni-card{padding:1.5rem;border-radius:var(--radius);background:var(--white);border:1px solid var(--gray-100);height:100%}
    .testimoni-card .stars{color:var(--accent);margin-bottom:0.5rem}
    .testimoni-card p{font-size:0.85rem;font-style:italic;color:var(--gray-600);line-height:1.7}
    .testimoni-card .author{font-weight:600;font-size:0.85rem;margin-top:0.5rem}
    .testimoni-card .position{font-size:0.75rem;color:var(--gray-400)}
    .kbli-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .kbli-item{display:flex;align-items:flex-start;gap:1rem;padding:1.25rem;border-radius:var(--radius-sm);background:var(--white);border:1px solid var(--gray-100)}
    .kbli-code{display:inline-block;background:rgba(49,46,95,0.08);color:var(--primary);font-weight:700;font-size:0.8rem;padding:0.2rem 0.6rem;border-radius:6px;white-space:nowrap;margin-top:0.1rem}
    .kbli-item div{font-size:0.85rem}
    .kbli-item strong{display:block;margin-bottom:0.15rem}
    .kbli-item span{font-size:0.78rem;color:var(--gray-500)}
    @media(max-width:767px){
      .about-grid,.legal-list,.kbli-grid{grid-template-columns:1fr}
    }
  </style>
</Layout>
