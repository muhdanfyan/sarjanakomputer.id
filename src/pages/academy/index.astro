---
import Layout from '../../layouts/Layout.astro';
import { PB_URL } from '../../utils/config.js';
import { getAcademyUrl } from '../../utils/routes.js';

// Fetch courses
const coursesRes = await fetch(`${PB_URL}/api/collections/courses/records?sort=created`);
const coursesData = await coursesRes.json();
const courses = coursesData.items || [];

// Fetch classes
const classesRes = await fetch(`${PB_URL}/api/collections/classes/records?sort=startDate`);
const classesData = await classesRes.json();
const classes = classesData.items || [];

// Map category icons/gradients
const gradients = [
  'linear-gradient(135deg,#8b5cf6,#6366f1)',
  'linear-gradient(135deg,#10b981,#059669)',
  'linear-gradient(135deg,#f59e0b,#f97316)',
  'linear-gradient(135deg,var(--secondary),#22d3ee)'
];

const icons = {
  'programming': 'laptop',
  'design': 'palette',
  'marketing': 'megaphone',
  'backend': 'diagram-2',
  'frontend': 'braces',
  'android': 'phone',
  'mobile': 'phone'
};
---

<Layout title="Sarjana Komputer Academy — Bootcamp & Pelatihan IT" description="Sarjana Komputer Academy — Bootcamp IT, bimbingan skripsi, dan pelatihan digital untuk mencetak talenta IT profesional." canonical={getAcademyUrl()} basePath=".." ogTitle="Sarjana Komputer Academy — Bootcamp & Pelatihan IT" ogDescription="Sarjana Komputer Academy — bootcamp coding, bimbingan skripsi, pelatihan IT, dan pengembangan talenta digital untuk siap bersaing di industri teknologi.">
  <!-- HERO -->
  <section class="hero-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-7">
          <div class="hero-badge"><i class="bi bi-mortarboard-fill"></i> Sarjana Komputer Academy</div>
          <h1>Bimbingan Skripsi — Jadi Sarjana Komputer <span style="background:var(--gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent">Profesional</span></h1>
          <p>Wadah pendidikan dan pelatihan IT untuk mencetak talenta digital unggulan — dari bootcamp intensif hingga bimbingan skripsi dan magang project-based.</p>
          <div class="d-flex flex-wrap gap-2 mt-3">
            <a href="#program" class="btn-primary-custom"><i class="bi bi-book"></i> Lihat Program</a>
            <a href="#daftar" class="btn-outline-custom" style="border-color:rgba(255,255,255,0.2);color:rgba(255,255,255,0.7);">Daftar Sekarang <i class="bi bi-arrow-right"></i></a>
          </div>
        </div>
        <div class="col-lg-5 text-center d-none d-lg-block">
          <i class="bi bi-mortarboard-fill" style="font-size:10rem;color:rgba(255,255,255,0.1)"></i>
        </div>
      </div>
    </div>
  </section>

  <!-- PROGRAM -->
  <section class="section" id="program">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(16,185,129,0.08);color:#10b981;border-color:rgba(16,185,129,0.15);display:inline-flex;margin-bottom:1rem"><i class="bi bi-book"></i> Program</div>
        <h2 class="section-title">Program Unggulan</h2>
        <p class="section-subtitle">Pilih jalur belajar yang sesuai dengan tujuan Anda</p>
       <div class="row g-3">
        {courses.map((course: any, index: number) => {
          const cat = (course.category || 'programming').toLowerCase();
          const icon = icons[cat] || 'laptop';
          const gradient = gradients[index % gradients.length];
          return (
            <div class="col-md-6 col-lg-3">
              <div class="program-card">
                <div class="icon" style={`background:${gradient}`}>
                  <i class={`bi bi-${icon}`}></i>
                </div>
                <h5>{course.title}</h5>
                <p>{course.description}</p>
                <div class="duration">
                  <i class="bi bi-clock"></i> {course.duration || '2 Bulan'}
                </div>
              </div>
            </div>
          );
        })}
        {courses.length === 0 && (
          <div class="col-12 text-center py-4">
            <p>Belum ada program kursus yang aktif.</p>
          </div>
        )}
      </div>      </div>
    </div>
  </section>

  <!-- PROGRAM TAMBAHAN -->
  <section class="section section-alt">
    <div class="container">
      <div class="row g-3">
        <div class="col-md-4">
          <div class="card-custom d-flex align-items-start gap-3" style="padding:1.5rem">
            <div class="card-icon" style="background:linear-gradient(135deg,var(--primary),var(--primary-light));width:48px;height:48px;font-size:1.1rem;flex-shrink:0"><i class="bi bi-pencil-square"></i></div>
            <div><h5 style="font-size:0.9rem;margin-bottom:0.2rem">Bimbingan Skripsi / Tugas Akhir</h5><p style="font-size:0.78rem;color:var(--gray-500);margin:0">Bantuan penuh untuk skripsi/tugas akhir — dari penentuan topik, konsultasi teknis, coding, sampai laporan siap sidang. Output: aplikasi jadi + laporan.</p></div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card-custom d-flex align-items-start gap-3" style="padding:1.5rem">
            <div class="card-icon" style="background:linear-gradient(135deg,#8b5cf6,#6366f1);width:48px;height:48px;font-size:1.1rem;flex-shrink:0"><i class="bi bi-briefcase"></i></div>
            <div><h5 style="font-size:0.9rem;margin-bottom:0.2rem">Magang / Project-Based</h5><p style="font-size:0.78rem;color:var(--gray-500);margin:0">Magang dan ikut ngerjain project real (Sipanda, SIMKES, dll). Dapat pengalaman, portfolio, dan sertifikat.</p></div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card-custom d-flex align-items-start gap-3" style="padding:1.5rem">
            <div class="card-icon" style="background:linear-gradient(135deg,#f59e0b,#f97316);width:48px;height:48px;font-size:1.1rem;flex-shrink:0"><i class="bi bi-mic"></i></div>
            <div><h5 style="font-size:0.9rem;margin-bottom:0.2rem">Webinar & Workshop</h5><p style="font-size:0.78rem;color:var(--gray-500);margin:0">Webinar dan workshop tematik — AI, Web Dev, Cybersecurity, dll. Baik online dan offline di Baubau.</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- JADWAL KELAS -->
  <section class="section section-alt" id="kelas">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem">
          <i class="bi bi-calendar-event"></i> Kelas
        </div>
        <h2 class="section-title">Jadwal Kelas Terdekat</h2>
        <p class="section-subtitle">Daftar kelas bootcamp aktif dan jadwal registrasi terdekat</p>
      </div>
      <div class="row g-3 justify-content-center">
        {classes.map((cls: any) => {
          const statusColors = {
            'Open': 'success',
            'Closed': 'danger',
            'Ongoing': 'warning'
          };
          const statusColor = statusColors[cls.status] || 'primary';
          
          return (
            <div class="col-md-6 col-lg-4">
              <div class="card-custom h-100 d-flex flex-column" style="padding:1.5rem">
                <div class="d-flex justify-content-between align-items-center mb-3">
                  <span class={`badge bg-${statusColor}`}>{cls.status}</span>
                  <small style="color:var(--gray-400);font-weight:600">Mulai: {new Date(cls.startDate).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</small>
                </div>
                <h5 style="font-size:1.05rem;margin-bottom:0.5rem">{cls.name}</h5>
                <p style="font-size:0.8rem;color:var(--gray-500);margin-bottom:1rem">
                  <strong>Course:</strong> {cls.course}<br/>
                  <strong>Mentor:</strong> {cls.mentor}<br/>
                  {cls.capacity && <span><strong>Kapasitas:</strong> {cls.capacity} Peserta</span>}
                </p>
                <div class="mt-auto">
                  {cls.status === 'Open' ? (
                    <a href="#daftar" class="btn-primary-custom w-100 justify-content-center" style="font-size:0.8rem;padding:0.45rem 1rem">
                      <i class="bi bi-pencil-square"></i> Daftar Sekarang
                    </a>
                  ) : (
                    <button class="btn btn-secondary w-100" disabled style="font-size:0.8rem;padding:0.45rem 1rem">
                      Pendaftaran Ditutup
                    </button>
                  )}
                </div>
              </div>
            </div>
          );
        })}
        {classes.length === 0 && (
          <div class="col-12 text-center py-4">
            <p>Belum ada jadwal kelas terdekat yang diumumkan.</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- MENTOR -->
  <section class="section" id="mentor">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem"><i class="bi bi-people"></i> Mentor</div>
        <h2 class="section-title">Tim Pengajar</h2>
        <p class="section-subtitle">Belajar langsung dari praktisi IT berpengalaman</p>
      </div>
      <div class="row g-3 justify-content-center">
        <div class="col-6 col-md-4 col-lg-2">
          <div class="mentor-card"><img loading="lazy" src="../images/team/direktur.webp" alt="Muhdan"><h6>Muhdan Fyan</h6><div class="role">Direktur / Mentor</div></div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
          <div class="mentor-card"><img loading="lazy" src="../images/team/hayat.webp" alt="Hayatul"><h6>Hayatul Habirun</h6><div class="role">IT Infra. Lead</div></div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
          <div class="mentor-card"><img loading="lazy" src="../images/team/arif-rizal.webp" alt="Arif"><h6>Arif Rizal</h6><div class="role">Backend & QA</div></div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
          <div class="mentor-card"><img loading="lazy" src="../images/team/ahmad-dahsan.webp" alt="Ahmad"><h6>Ahmad Dahsan</h6><div class="role">DevOps Engineer</div></div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
          <div class="mentor-card"><img loading="lazy" src="../images/team/andi-rifqial-nur.webp" alt="Andi"><h6>Andi Rifqial N.</h6><div class="role">Software Eng.</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="section section-alt" id="biaya">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem"><i class="bi bi-wallet2"></i> Biaya</div>
        <h2 class="section-title">Estimasi Biaya Program</h2>
        <p class="section-subtitle">Investasi untuk masa depan karir IT Anda</p>
      </div>
      <div class="row g-3 justify-content-center">
        <div class="col-md-6 col-lg-4">
          <div class="price-card"><h5>Bootcamp Full-stack</h5><div class="amount">2-3jt</div><p style="font-size:0.82rem;color:var(--gray-500)">Durasi 3 bulan, termasuk modul, mentoring, dan sertifikat</p><ul><li><i class="bi bi-check-circle"></i> Modul lengkap</li><li><i class="bi bi-check-circle"></i> Project portfolio</li><li><i class="bi bi-check-circle"></i> Sertifikat kelulusan</li></ul></div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="price-card"><h5>Bimbingan Skripsi</h5><div class="amount">1-2jt</div><p style="font-size:0.82rem;color:var(--gray-500)">Periode 3-6 bulan, bimbingan intensif sampai selesai</p><ul><li><i class="bi bi-check-circle"></i> Konsultasi topik</li><li><i class="bi bi-check-circle"></i> Bimbingan coding</li><li><i class="bi bi-check-circle"></i> Aplikasi jadi + laporan</li></ul></div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="price-card"><h5>Bootcamp Spesifik</h5><div class="amount">1-1.5jt</div><p style="font-size:0.82rem;color:var(--gray-500)">Backend/Frontend/Android — 2 bulan, intensif, praktik</p><ul><li><i class="bi bi-check-circle"></i> Modul terfokus</li><li><i class="bi bi-check-circle"></i> Project sesuai bidang</li><li><i class="bi bi-check-circle"></i> Sertifikat</li></ul></div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="section">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem"><i class="bi bi-chat-quote"></i> Testimoni</div>
        <h2 class="section-title">Apa Kata Alumni?</h2>
        <p class="section-subtitle">Pengalaman mereka setelah mengikuti program</p>
      </div>
      <div class="row g-3">
        <div class="col-md-4">
          <div class="testimonial-card"><div class="quote">"Bootcamp Full-stack di Sarjana Komputer Academy benar-benar mengubah karir saya. Dari nol bisa bikin web sendiri dalam 3 bulan."</div><div class="author"><img loading="lazy" src="../images/team/arif-rizal.webp" alt="Alumni"><span>— Rifaldi, <span style="font-weight:400;color:var(--gray-500)">Alumni 2025</span></span></div></div>
        </div>
        <div class="col-md-4">
          <div class="testimonial-card"><div class="quote">"Bimbingan skripsinya sangat membantu. Dari bingung mau buat apa, jadi punya aplikasi jadi dan lulus tepat waktu."</div><div class="author"><img loading="lazy" src="../images/team/hayat.webp" alt="Alumni"><span>— St. Rahma, <span style="font-weight:400;color:var(--gray-500)">Alumni Bimbingan 2025</span></span></div></div>
        </div>
        <div class="col-md-4">
          <div class="testimonial-card"><div class="quote">"Program magang di sini beneran ngerjain proyek nyata, bukan cuma teori. Portfolio saya jadi kuat."</div><div class="author"><img loading="lazy" src="../images/team/direktur.webp" alt="Alumni"><span>— Akbar, <span style="font-weight:400;color:var(--gray-500)">Peserta Magang 2025</span></span></div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cross Link -->
  <div class="text-center mt-4">
    <p style="font-size:0.85rem;color:var(--gray-500)">Lihat juga <a href="../aplikasi/" style="color:var(--primary);font-weight:600">Jasa Aplikasi</a> · <a href="../automasi/" style="color:var(--primary);font-weight:600">Automasi & AI</a></p>
  </div>

  <!-- DAFTAR -->
  <section class="section section-alt" id="daftar">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="text-center mb-3">
            <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem"><i class="bi bi-pencil-square"></i> Pendaftaran</div>
            <h2 class="section-title">Daftar Sekarang</h2>
            <p class="section-subtitle">Isi form di bawah, tim kami akan menghubungi Anda</p>
          </div>
          <form class="register-form" action="https://formspree.io/f/your-form-id" method="POST" style="display:grid;gap:0.75rem">
            <div class="row g-2">
              <div class="col-md-6"><input class="form-control" type="text" name="nama" placeholder="Nama Lengkap" required></div>
              <div class="col-md-6"><input class="form-control" type="email" name="email" placeholder="Email" required></div>
            </div>
            <div class="row g-2">
              <div class="col-md-6"><input class="form-control" type="tel" name="wa" placeholder="No. WhatsApp"></div>
              <div class="col-md-6">
                <select class="form-control" name="program" required style="border-radius:10px;padding:0.6rem 1rem;font-size:0.85rem;border:1px solid #dee2e6;width:100%">
                  <option value="">Pilih Program</option>
                  {courses.map((course: any) => (
                    <option value={course.title}>{course.title}</option>
                  ))}
                  <option>Bimbingan Skripsi</option>
                  <option>Magang / Project-Based</option>
                </select>
              </div>
            </div>
            <textarea class="form-control" name="pesan" rows="3" placeholder="Pesan (opsional)"></textarea>
            <button class="btn-primary-custom" type="submit" style="justify-content:center;padding:0.65rem 1.8rem"><i class="bi bi-send"></i> Kirim Pendaftaran</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <style>
    .program-card{text-align:center;padding:2rem 1.5rem;border-radius:var(--radius);background:var(--white);border:1px solid var(--gray-100);height:100%;transition:0.4s}
    .program-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-lg)}
    .program-card .icon{width:64px;height:64px;border-radius:18px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.6rem;color:white}
    .program-card h5{font-size:0.95rem;margin-bottom:0.3rem}
    .program-card p{font-size:0.8rem;color:var(--gray-500);margin-bottom:0.75rem}
    .program-card .duration{font-size:0.75rem;color:var(--gray-400)}
    .mentor-card{text-align:center;padding:1.5rem;border-radius:var(--radius);background:var(--white);border:1px solid var(--gray-100);height:100%;transition:0.4s}
    .mentor-card:hover{box-shadow:var(--shadow);transform:translateY(-3px)}
    .mentor-card img{width:90px;height:90px;border-radius:50%;object-fit:cover;margin-bottom:0.75rem;border:3px solid rgba(49,46,95,0.1)}
    .mentor-card h6{font-size:0.88rem;margin-bottom:0.05rem}
    .mentor-card .role{font-size:0.72rem;color:var(--primary);font-weight:600}
    .price-card{padding:1.5rem;border-radius:var(--radius);border:1px solid var(--gray-100);height:100%;transition:0.3s}
    .price-card:hover{box-shadow:var(--shadow)}
    .price-card h5{font-size:0.95rem;margin-bottom:0.2rem}
    .price-card .amount{font-size:1.5rem;font-weight:800;color:var(--primary);margin:0.3rem 0}
    .price-card ul{list-style:none;padding:0;margin:0.5rem 0}
    .price-card ul li{font-size:0.8rem;padding:0.2rem 0;display:flex;align-items:center;gap:0.4rem;color:var(--gray-600)}
    .price-card ul li i{color:#10b981}
    .testimonial-card{padding:1.25rem;border-radius:var(--radius);background:var(--white);border:1px solid var(--gray-100);height:100%}
    .testimonial-card .quote{font-size:0.82rem;font-style:italic;color:var(--gray-600);line-height:1.7}
    .testimonial-card .author{font-weight:600;font-size:0.82rem;margin-top:0.5rem;display:flex;align-items:center;gap:0.5rem}
    .testimonial-card .author img{width:36px;height:36px;border-radius:50%;object-fit:cover}
    .register-form .form-control{border-radius:10px;padding:0.6rem 1rem;font-size:0.85rem}
    @media(max-width:767px){
      .program-card{padding:1.5rem 1rem}
      .price-card .amount{font-size:1.2rem}
    }
  </style>
</Layout>
