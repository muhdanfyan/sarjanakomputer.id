---
import Layout from "../layouts/Layout.astro";
---

<Layout title="CV. Sarjana Komputer Indonesia — Kontak">
<div class="page-header">
        <div class="container">
            <a href="index.html" class="back-link"><i class="bi bi-arrow-left"></i> Kembali ke Beranda</a>
            <h1>Hubungi Kami</h1>
            <p>Diskusikan kebutuhan IT Anda</p>
        </div>
    </div>
    <section>
        <div class="container">
            <div class="row g-4 justify-content-center">
                <div class="col-lg-5">
                    <div class="card mb-3 p-3 border-0 shadow-sm">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-geo-alt-fill fs-3" style="color: var(--primary);"></i>
                            <div><h6>Alamat</h6><p class="mb-0" style="color: var(--gray-500);">Baubau, Sulawesi Tenggara, Indonesia</p></div>
                        </div>
                    </div>
                    <div class="card mb-3 p-3 border-0 shadow-sm">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-envelope-fill fs-3" style="color: var(--primary);"></i>
                            <div><h6>Email</h6><p class="mb-0" style="color: var(--gray-500);">sarjanakomputer.id@gmail.com</p></div>
                        </div>
                    </div>
                    <div class="card mb-3 p-3 border-0 shadow-sm">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-whatsapp fs-3" style="color: #25d366;"></i>
                            <div><h6>WhatsApp</h6><p class="mb-0" style="color: var(--gray-500);">+62 823-4567-8901</p></div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-3">
                        <a href="https://wa.me/6282345678901" class="btn btn-success rounded-pill px-4"><i class="bi bi-whatsapp"></i> WhatsApp</a>
                        <a href="mailto:sarjanakomputer.id@gmail.com" class="btn btn-outline-primary rounded-pill px-4"><i class="bi bi-envelope"></i> Email</a>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="card p-4 border-0 shadow-sm">
                        <h5>Kirim Pesan</h5>
                        <form action="https://formspree.io/f/xqapqkwa" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Nama</label>
                                <input type="text" class="form-control" name="nama" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" name="email" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Pesan</label>
                                <textarea class="form-control" name="pesan" rows="4" required></textarea>
                            </div>
                            <button type="submit" class="btn" style="background: var(--gradient); color: white; border-radius: 50px; padding: 0.6rem 2rem;">Kirim</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
if('serviceWorker'in navigator){navigator.serviceWorker.register('/sw.js');}
</script>
</Layout>
