---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Jasa Aplikasi — Sarjana Komputer Indonesia" description="Jasa pembuatan aplikasi web, mobile Android, dan desktop custom dari CV. Sarjana Komputer Indonesia" canonical="https://aplikasi.sarjanakomputer.id/aplikasi/" basePath=".." ogTitle="Jasa Aplikasi — Sarjana Komputer Indonesia" ogDescription="Jasa pembuatan aplikasi web, mobile Android, dan desktop custom. Dari sistem informasi, aplikasi desa, hingga platform digital — harga terjangkau, kualitas profesional.">
  <!-- HERO -->
  <section class="hero-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-7">
          <div class="hero-badge"><i class="bi bi-window-stack"></i> Jasa Aplikasi</div>
          <h1>Jasa Pembuatan Aplikasi <span style="background:var(--gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent">Professional & Terjangkau</span></h1>
          <p>Dari konsultasi hingga peluncuran — kami bantu Anda mewujudkan aplikasi web, mobile, dan desktop sesuai kebutuhan bisnis.</p>
          <div class="d-flex flex-wrap gap-2 mt-3">
            <a href="#pricing" class="btn-primary-custom"><i class="bi bi-tags"></i> Lihat Paket</a>
            <a href="#proses" class="btn-outline-custom" style="border-color:rgba(255,255,255,0.2);color:rgba(255,255,255,0.7);">Bagaimana Cara Kerjanya? <i class="bi bi-arrow-right"></i></a>
          </div>
        </div>
        <div class="col-lg-5 text-center d-none d-lg-block">
          <i class="bi bi-window-stack" style="font-size:10rem;color:rgba(255,255,255,0.1)"></i>
        </div>
      </div>
    </div>
  </section>

  <!-- LAYANAN -->
  <section class="section" id="layanan">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem"><i class="bi bi-grid"></i> Layanan</div>
        <h2 class="section-title">Apa yang Kami Buat?</h2>
        <p class="section-subtitle">Solusi aplikasi untuk berbagai platform dan kebutuhan</p>
      </div>
      <div class="row g-3">
        <div class="col-md-6 col-lg-3">
          <div class="card-custom text-center" style="padding:2rem 1.5rem">
            <div class="service-icon lg" style="background:linear-gradient(135deg,var(--primary),var(--primary-light));margin:0 auto 1rem"><i class="bi bi-globe2"></i></div>
            <h5 style="font-size:1rem">Website & Web App</h5>
            <p style="font-size:0.82rem;color:var(--gray-500)">Company profile, portal berita, sistem informasi, dashboard, e-commerce, dan aplikasi web lainnya.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-3">
          <div class="card-custom text-center" style="padding:2rem 1.5rem">
            <div class="service-icon lg" style="background:linear-gradient(135deg,#8b5cf6,#6366f1);margin:0 auto 1rem"><i class="bi bi-phone"></i></div>
            <h5 style="font-size:1rem">Aplikasi Android</h5>
            <p style="font-size:0.82rem;color:var(--gray-500)">Aplikasi mobile Android native untuk kebutuhan internal perusahaan maupun publik.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-3">
          <div class="card-custom text-center" style="padding:2rem 1.5rem">
            <div class="service-icon lg" style="background:linear-gradient(135deg,#10b981,#059669);margin:0 auto 1rem"><i class="bi bi-pc-display"></i></div>
            <h5 style="font-size:1rem">Aplikasi Desktop</h5>
            <p style="font-size:0.82rem;color:var(--gray-500)">Aplikasi Windows/Linux untuk manajemen internal, kasir, inventory, dan operasional kantor.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-3">
          <div class="card-custom text-center" style="padding:2rem 1.5rem">
            <div class="service-icon lg" style="background:linear-gradient(135deg,#f59e0b,#f97316);margin:0 auto 1rem"><i class="bi bi-diagram-2"></i></div>
            <h5 style="font-size:1rem">Sistem Informasi</h5>
            <p style="font-size:0.82rem;color:var(--gray-500)">Sistem informasi pemerintahan (e-government), manajemen kesehatan, retribusi, dan lainnya.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROSES -->
  <section class="section section-alt" id="proses">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem"><i class="bi bi-arrow-repeat"></i> Proses</div>
        <h2 class="section-title">Bagaimana Cara Kerjanya?</h2>
        <p class="section-subtitle">Proses sederhana dan transparan dari awal hingga akhir</p>
      </div>
      <div class="row g-3">
        <div class="col-md-4">
          <div class="card-custom d-flex align-items-start gap-3" style="padding:1.5rem">
            <div class="step-num" style="background:var(--gradient)">1</div>
            <div><h5 style="font-size:0.95rem;margin-bottom:0.3rem">Konsultasi & Analisis</h5><p style="font-size:0.82rem;color:var(--gray-500);margin:0">Diskusi kebutuhan, tujuan, dan scope proyek. Kami bantu Anda merumuskan aplikasi yang tepat.</p></div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card-custom d-flex align-items-start gap-3" style="padding:1.5rem">
            <div class="step-num" style="background:var(--gradient)">2</div>
            <div><h5 style="font-size:0.95rem;margin-bottom:0.3rem">Desain & Pengembangan</h5><p style="font-size:0.82rem;color:var(--gray-500);margin:0">Tim kami merancang UI/UX dan mengembangkan aplikasi dengan teknologi terbaik.</p></div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card-custom d-flex align-items-start gap-3" style="padding:1.5rem">
            <div class="step-num" style="background:var(--gradient)">3</div>
            <div><h5 style="font-size:0.95rem;margin-bottom:0.3rem">Launch & Maintenance</h5><p style="font-size:0.82rem;color:var(--gray-500);margin:0">Deploy, uji coba, peluncuran resmi. Layanan maintenance dan support berkelanjutan.</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PAKET HARGA -->
  <section class="section" id="pricing">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem"><i class="bi bi-tags"></i> Harga</div>
        <h2 class="section-title">Paket Layanan</h2>
        <p class="section-subtitle">Sesuaikan dengan kebutuhan dan anggaran Anda</p>
      </div>
      <div class="row g-3 justify-content-center">
        <div class="col-md-6 col-lg-4">
          <div class="pricing-card">
            <h5 style="font-size:1.05rem">Basic</h5>
            <div class="price">3-5jt <span>/proyek</span></div>
            <ul><li><i class="bi bi-check-circle"></i> Website company profile / landing page</li><li><i class="bi bi-check-circle"></i> Desain responsif mobile & desktop</li><li><i class="bi bi-check-circle"></i> 1x revisi desain</li><li><i class="bi bi-check-circle"></i> Hosting + domain 1 tahun</li><li><i class="bi bi-check-circle"></i> Support 1 bulan</li></ul>
            <a href="../profil/#kontak" class="btn-outline-custom" style="font-size:0.82rem;padding:0.5rem 1.4rem">Pilih Paket</a>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="pricing-card popular">
            <div class="popular-badge">POPULER</div>
            <h5 style="font-size:1.05rem">Business</h5>
            <div class="price">8-15jt <span>/proyek</span></div>
            <ul><li><i class="bi bi-check-circle"></i> Aplikasi web / sistem informasi</li><li><i class="bi bi-check-circle"></i> Desain UI/UX profesional</li><li><i class="bi bi-check-circle"></i> Database + API</li><li><i class="bi bi-check-circle"></i> Dashboard admin</li><li><i class="bi bi-check-circle"></i> Support & maintenance 3 bulan</li><li><i class="bi bi-check-circle"></i> Pelatihan penggunaan</li></ul>
            <a href="../profil/#kontak" class="btn-primary-custom" style="font-size:0.82rem;padding:0.5rem 1.4rem">Pilih Paket</a>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="pricing-card">
            <h5 style="font-size:1.05rem">Enterprise</h5>
            <div class="price">Custom <span>/proyek</span></div>
            <ul><li><i class="bi bi-check-circle"></i> Aplikasi kompleks (multi-modul)</li><li><i class="bi bi-check-circle"></i> Web + Mobile + Desktop</li><li><i class="bi bi-check-circle"></i> Integrasi sistem pihak ketiga</li><li><i class="bi bi-check-circle"></i> Cloud infrastructure</li><li><i class="bi bi-check-circle"></i> SLA & support prioritas</li><li><i class="bi bi-check-circle"></i> Maintenance & update berkala</li></ul>
            <a href="../profil/#kontak" class="btn-outline-custom" style="font-size:0.82rem;padding:0.5rem 1.4rem">Hubungi Kami</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PORTOFOLIO -->
  <section class="section section-alt" id="portofolio">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem"><i class="bi bi-folder2-open"></i> Portofolio</div>
        <h2 class="section-title">Proyek Terbaru</h2>
        <p class="section-subtitle">Beberapa aplikasi yang telah kami buat</p>
      </div>
      <div class="row g-3">
        <div class="col-md-4">
          <div class="card-custom"><div class="project-card-img" style="height:140px;background:linear-gradient(135deg,var(--primary),var(--primary-light));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:2.5rem;color:rgba(255,255,255,0.5);margin-bottom:1rem"><i class="bi bi-building-gear"></i></div><h5 style="font-size:0.95rem">Sipanda v2.0</h5><p style="font-size:0.8rem;color:var(--gray-500)">Sistem Informasi Pendapatan Daerah</p><span class="project-tag" style="font-size:0.7rem;background:rgba(49,46,95,0.08);color:var(--primary);padding:0.15rem 0.6rem;border-radius:4px;font-weight:600">Pemerintahan</span></div>
        </div>
        <div class="col-md-4">
          <div class="card-custom"><div class="project-card-img" style="height:140px;background:linear-gradient(135deg,#10b981,#059669);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:2.5rem;color:rgba(255,255,255,0.5);margin-bottom:1rem"><i class="bi bi-heart-pulse"></i></div><h5 style="font-size:0.95rem">SIMKES</h5><p style="font-size:0.8rem;color:var(--gray-500)">Sistem Informasi Manajemen Kesehatan</p><span class="project-tag" style="font-size:0.7rem;background:rgba(49,46,95,0.08);color:var(--primary);padding:0.15rem 0.6rem;border-radius:4px;font-weight:600">Pemerintahan</span></div>
        </div>
        <div class="col-md-4">
          <div class="card-custom"><div class="project-card-img" style="height:140px;background:linear-gradient(135deg,#f59e0b,#f97316);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:2.5rem;color:rgba(255,255,255,0.5);margin-bottom:1rem"><i class="bi bi-credit-card-2-front"></i></div><h5 style="font-size:0.95rem">E-Retribusi</h5><p style="font-size:0.8rem;color:var(--gray-500)">Platform pembayaran retribusi online</p><span class="project-tag" style="font-size:0.7rem;background:rgba(49,46,95,0.08);color:var(--primary);padding:0.15rem 0.6rem;border-radius:4px;font-weight:600">Pemerintahan</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <div class="text-center">
        <div class="hero-badge" style="background:rgba(49,46,95,0.08);color:var(--primary);border-color:rgba(49,46,95,0.15);display:inline-flex;margin-bottom:1rem"><i class="bi bi-question-circle"></i> FAQ</div>
        <h2 class="section-title">Pertanyaan Umum</h2>
        <p class="section-subtitle">Hal-hal yang sering ditanyakan seputar pembuatan aplikasi</p>
      </div>
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="faq-item"><div class="faq-q" onclick="toggleFaq(this)">Berapa lama waktu pembuatan aplikasi? <i class="bi bi-chevron-down"></i></div><div class="faq-a">Tergantung kompleksitas. Untuk website company profile sekitar 1-2 minggu. Aplikasi sistem informasi 3-6 minggu. Aplikasi kompleks bisa 2-3 bulan.</div></div>
          <div class="faq-item"><div class="faq-q" onclick="toggleFaq(this)">Apakah menyediakan hosting? <i class="bi bi-chevron-down"></i></div><div class="faq-a">Ya, kami menyediakan paket hosting + domain untuk website dan aplikasi web. Tersedia juga opsi cloud hosting untuk aplikasi berskala besar.</div></div>
          <div class="faq-item"><div class="faq-q" onclick="toggleFaq(this)">Bagaimana dengan maintenance setelah aplikasi selesai? <i class="bi bi-chevron-down"></i></div><div class="faq-a">Kami menyediakan layanan maintenance bulanan untuk memastikan aplikasi tetap berjalan optimal, termasuk update keamanan, backup data, dan bantuan teknis.</div></div>
          <div class="faq-item"><div class="faq-q" onclick="toggleFaq(this)">Apakah bisa request fitur tertentu? <i class="bi bi-chevron-down"></i></div><div class="faq-a">Tentu. Kami selalu mendiskusikan kebutuhan fitur di awal. Jika ada tambahan fitur di tengah proses, kami akan sesuaikan dengan timeline dan biaya.</div></div>
          <div class="faq-item"><div class="faq-q" onclick="toggleFaq(this)">Teknologi apa yang digunakan? <i class="bi bi-chevron-down"></i></div><div class="faq-a">Kami menggunakan teknologi modern: Laravel/Go/NestJS untuk backend, React/Next.js/Vue untuk frontend, Flutter/Kotlin untuk Android, MySQL/PostgreSQL untuk database.</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-alt">
    <div class="container text-center">
      <h2 class="section-title">Siap Membuat Aplikasi?</h2>
      <p class="section-subtitle">Konsultasi gratis tanpa biaya. Ceritakan kebutuhan Anda, kami bantu wujudkan.</p>
      <a href="../profil/#kontak" class="btn-primary-custom"><i class="bi bi-whatsapp"></i> Konsultasi Gratis</a>
    </div>
  </section>

  <style>
    .service-icon.lg{width:72px;height:72px;border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:1.8rem;color:white;margin-bottom:1rem}
    .step-num{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:800;color:white;margin-bottom:0.75rem;flex-shrink:0}
    .pricing-card{text-align:center;padding:2rem 1.5rem;border-radius:var(--radius);background:var(--white);border:1px solid var(--gray-100);height:100%;position:relative;transition:0.4s}
    .pricing-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-lg)}
    .pricing-card.popular{border-color:var(--primary);box-shadow:0 0 0 2px var(--primary)}
    .pricing-card .price{font-size:2rem;font-weight:800;color:var(--dark)}
    .pricing-card .price span{font-size:0.9rem;font-weight:400;color:var(--gray-500)}
    .pricing-card ul{text-align:left;list-style:none;padding:0;margin:1.5rem 0}
    .pricing-card ul li{padding:0.45rem 0;font-size:0.85rem;display:flex;align-items:center;gap:0.5rem;border-bottom:1px solid var(--gray-50)}
    .pricing-card ul li i{color:#10b981}
    .popular-badge{position:absolute;top:-0.75rem;left:50%;transform:translateX(-50%);padding:0.3rem 1.2rem;background:var(--gradient);color:white;border-radius:50px;font-size:0.72rem;font-weight:700}
    .faq-item{padding:1rem 0;border-bottom:1px solid var(--gray-100)}
    .faq-item:last-child{border-bottom:none}
    .faq-q{font-weight:600;font-size:0.92rem;cursor:pointer;display:flex;justify-content:space-between;align-items:center;color:var(--dark)}
    .faq-q i{transition:0.3s;font-size:0.8rem;color:var(--gray-400)}
    .faq-q.open i{transform:rotate(180deg)}
    .faq-a{font-size:0.85rem;color:var(--gray-500);padding-top:0.5rem;line-height:1.7;display:none}
    .faq-a.show{display:block}
    @media(max-width:767px){
      .pricing-card{padding:1.5rem 1rem}
      .pricing-card .price{font-size:1.5rem}
    }
  </style>
</Layout>
