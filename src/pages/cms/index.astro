---
import fs from 'node:fs';
import path from 'node:path';

// Load compiled HTML from Vue SPA and serve it as the Astro entry point for /cms/
const htmlPath = path.resolve(process.cwd(), 'public/cms/index.html');
let html = '';
try {
  html = fs.readFileSync(htmlPath, 'utf-8');
} catch (e) {
  html = '<!DOCTYPE html><html><head><title>Loading CMS</title></head><body><h2>CMS is not built yet. Please run <code>npm run build:cms</code> in your terminal.</h2></body></html>';
}
---

<Fragment set:html={html} />
