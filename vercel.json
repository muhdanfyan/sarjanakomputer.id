{
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/news",
      "has": [
        {
          "type": "host",
          "value": "sarjanakomputer.id"
        }
      ],
      "destination": "https://news.sarjanakomputer.id/",
      "permanent": true
    },
    {
      "source": "/news/:path*",
      "has": [
        {
          "type": "host",
          "value": "sarjanakomputer.id"
        }
      ],
      "destination": "https://news.sarjanakomputer.id/:path*",
      "permanent": true
    },
    {
      "source": "/academy",
      "has": [
        {
          "type": "host",
          "value": "sarjanakomputer.id"
        }
      ],
      "destination": "https://academy.sarjanakomputer.id/",
      "permanent": true
    },
    {
      "source": "/academy/:path*",
      "has": [
        {
          "type": "host",
          "value": "sarjanakomputer.id"
        }
      ],
      "destination": "https://academy.sarjanakomputer.id/:path*",
      "permanent": true
    },
    {
      "source": "/profil",
      "has": [
        {
          "type": "host",
          "value": "sarjanakomputer.id"
        }
      ],
      "destination": "https://profil.sarjanakomputer.id/",
      "permanent": true
    },
    {
      "source": "/profil/:path*",
      "has": [
        {
          "type": "host",
          "value": "sarjanakomputer.id"
        }
      ],
      "destination": "https://profil.sarjanakomputer.id/:path*",
      "permanent": true
    },
    {
      "source": "/aplikasi",
      "has": [
        {
          "type": "host",
          "value": "sarjanakomputer.id"
        }
      ],
      "destination": "https://aplikasi.sarjanakomputer.id/",
      "permanent": true
    },
    {
      "source": "/aplikasi/:path*",
      "has": [
        {
          "type": "host",
          "value": "sarjanakomputer.id"
        }
      ],
      "destination": "https://aplikasi.sarjanakomputer.id/:path*",
      "permanent": true
    },
    {
      "source": "/automasi",
      "has": [
        {
          "type": "host",
          "value": "sarjanakomputer.id"
        }
      ],
      "destination": "https://automasi.sarjanakomputer.id/",
      "permanent": true
    },
    {
      "source": "/automasi/:path*",
      "has": [
        {
          "type": "host",
          "value": "sarjanakomputer.id"
        }
      ],
      "destination": "https://automasi.sarjanakomputer.id/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "news.sarjanakomputer.id"
        }
      ],
      "destination": "/news/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "academy.sarjanakomputer.id"
        }
      ],
      "destination": "/academy/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "profil.sarjanakomputer.id"
        }
      ],
      "destination": "/profil/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "aplikasi.sarjanakomputer.id"
        }
      ],
      "destination": "/aplikasi/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "automasi.sarjanakomputer.id"
        }
      ],
      "destination": "/automasi/$1"
    }
  ]
}
