{
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/news",
      "has": [
        {
          "type": "host",
          "value": "sarjanakomputer.id"
        }
      ],
      "destination": "https://news.sarjanakomputer.id/",
      "permanent": true
    },
    {
      "source": "/news/:path*",
      "has": [
        {
          "type": "host",
          "value": "sarjanakomputer.id"
        }
      ],
      "destination": "https://news.sarjanakomputer.id/:path*",
      "permanent": true
    },
