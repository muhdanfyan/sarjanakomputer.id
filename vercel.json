{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "redirects": [
    { "source": "/about.html", "destination": "/about/", "permanent": true },
    { "source": "/contact.html", "destination": "/contact/", "permanent": true },
    { "source": "/services.html", "destination": "/services/", "permanent": true },
    { "source": "/struktur-organisasi.html", "destination": "/struktur-organisasi/", "permanent": true },
    
    { "source": "/news", "destination": "https://news.sarjanakomputer.id/", "permanent": true, "has": [{ "type": "host", "value": "sarjanakomputer.id" }] },
    { "source": "/news/", "destination": "https://news.sarjanakomputer.id/", "permanent": true, "has": [{ "type": "host", "value": "sarjanakomputer.id" }] },
    { "source": "/news/:path*", "destination": "https://news.sarjanakomputer.id/:path*", "permanent": true, "has": [{ "type": "host", "value": "sarjanakomputer.id" }] },

    { "source": "/news", "destination": "https://news.sarjanakomputer.id/", "permanent": true, "has": [{ "type": "host", "value": "www.sarjanakomputer.id" }] },
    { "source": "/news/", "destination": "https://news.sarjanakomputer.id/", "permanent": true, "has": [{ "type": "host", "value": "www.sarjanakomputer.id" }] },
    { "source": "/news/:path*", "destination": "https://news.sarjanakomputer.id/:path*", "permanent": true, "has": [{ "type": "host", "value": "www.sarjanakomputer.id" }] },

    { "source": "/news/:path*", "destination": "/:path*", "permanent": true, "has": [{ "type": "host", "value": "news.sarjanakomputer.id" }] },

    { "source": "/admin/", "destination": "/news/admin/index.html", "has": [{ "type": "host", "value": "news.sarjanakomputer.id" }] },
    { "source": "/admin", "destination": "/news/admin/index.html", "has": [{ "type": "host", "value": "news.sarjanakomputer.id" }] },
    { "source": "/admin/:path*", "destination": "/news/admin/:path*", "has": [{ "type": "host", "value": "news.sarjanakomputer.id" }] },

    { "source": "/", "destination": "/news/index.html", "has": [{ "type": "host", "value": "news.sarjanakomputer.id" }] },
    { "source": "/artikel.html", "destination": "/news/artikel.html", "has": [{ "type": "host", "value": "news.sarjanakomputer.id" }] },
    { "source": "/content/:path*", "destination": "/news/content/:path*", "has": [{ "type": "host", "value": "news.sarjanakomputer.id" }] }
    ]
    }
}
